    {
      "start": 167.96,
      "end": 168.96,
      "text": "现实生活"
    },
    {
      "start": 168.96,
      "end": 171.24,
      "text": "你比他过有多好吗"
    },
    {
      "start": 171.24,
      "end": 173.48,
      "text": "你是显得黄石"
