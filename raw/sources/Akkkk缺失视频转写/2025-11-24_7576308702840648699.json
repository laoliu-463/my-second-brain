    },
    {
      "start": 258.01,
      "end": 260.49,
      "text": "可能其实当你达到一个"
    },
    {
      "start": 260.49,
      "end": 262.81,
      "text": "来为了说你会发现"
    },
    {
      "start": 262.81,
      "end": 263.81,
      "text": "讲得不错"
    },
    {
      "start": 263.81,
      "end": 265.77,
      "text": "各方面条件也还多"
    },
    {
      "start": 265.77,
      "end": 268.77,
      "text": "包括这个不少"
