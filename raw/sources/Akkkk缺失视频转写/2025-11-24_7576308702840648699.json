    {
      "start": 295.61,
      "end": 297.13,
      "text": "有一些老现目制度"
    },
    {
      "start": 297.13,
      "end": 298.97,
      "text": "很能理解身体身自己"
    },
    {
      "start": 298.97,
      "end": 301.21,
