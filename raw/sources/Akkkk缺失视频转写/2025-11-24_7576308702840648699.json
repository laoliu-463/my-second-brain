    },
    {
      "start": 73.42,
      "end": 75.58,
      "text": "现在太痛痛"
    },
    {
      "start": 75.58,
      "end": 78.52,
      "text": "太痛"
    },
    {
      "start": 78.52,
      "end": 79.28,
      "text": "太清楚吧"
    },
    {
      "start": 79.28,
      "end": 81.28,
      "text": "那一方作为一下组续高"
    },
    {
      "start": 81.28,
      "end": 82.8,
