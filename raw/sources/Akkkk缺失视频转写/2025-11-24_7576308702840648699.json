    },
    {
      "start": 184.48,
      "end": 187.24,
      "text": "现实生活中一个高生态为"
    },
    {
      "start": 187.24,
      "end": 197.46,
      "text": "就要会去演介绍的意思"
    },
    {
      "start": 197.46,
      "end": 201.76,
      "text": "A9"
    },
    {
      "start": 201.76,
      "end": 203.56,
      "text": "我为的A9"
    },
    {
      "start": 203.56,
      "end": 205.72,
