      "text": "这就做大见了"
    },
    {
      "start": 436.34,
      "end": 437.82,
      "text": "大保健做做完美好"
    },
    {
      "start": 437.82,
      "end": 440.02,
      "text": "你做得能刀吗"
    },
    {
      "start": 440.02,
      "end": 441.18,
      "text": "这种节闭起什么"
    },
    {
      "start": 441.18,
      "end": 442.22,
      "text": "做刀吗"
    },
    {
      "start": 442.22,
      "end": 445.03,
      "text": "我开始做那种"
    },
    {
      "start": 445.03,
      "end": 446.63,
      "text": "像造像"
    },
    {
      "start": 446.63,
      "end": 452.41,
      "text": "像你干"
    },
    {
      "start": 452.41,
      "end": 455.78,
      "text": "把大线走运走"
    },
    {
      "start": 455.78,
      "end": 457.78,
      "text": "拿下"
    },
    {
      "start": 457.78,
      "end": 459.02,
      "text": "小见买不动"
    },
    {
      "start": 459.02,
      "end": 461.58,
      "text": "你会买买大线"
    },
    {
      "start": 461.58,
      "end": 463.26,
      "text": "什么"
    },
    {
      "start": 463.26,
      "end": 465.38,
      "text": "你不愿意投入那么多成员"
    },
    {
      "start": 465.38,
      "end": 466.74,
      "text": "生意"
    },
    {
      "start": 466.74,
      "end": 467.94,
      "text": "是随时在换的"
    },
    {
      "start": 467.94,
      "end": 469.14,
      "text": "在编动的"
    }
  ]
}