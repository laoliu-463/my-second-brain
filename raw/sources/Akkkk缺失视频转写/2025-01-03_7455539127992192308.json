{
  "aweme_id": "7455539127992192308",
  "language": "zh",
  "duration": 76.83625,
  "segments": [
    {
      "start": 0.0,
      "end": 1.54,
      "text": "我直播的时候怎么说的"
    },
    {
      "start": 1.54,
      "end": 4.38,
      "text": "阿川这不有遭遇刺客心调了吗"
    },
    {
      "start": 4.38,
      "end": 6.34,
      "text": "这遇测不有队了吗"
    },
    {
      "start": 6.34,
      "end": 9.4,
      "text": "当时还有人说谁敢 谁敢"
    },
    {
      "start": 9.4,
      "end": 11.88,
      "text": "怎么会不敢 遇测"
    },
    {
      "start": 11.88,
      "end": 14.48,
      "text": "在某种文化里面的遇测"
    },
    {
      "start": 14.48,
      "end": 17.82,
      "text": "不是说一定会发生在这个人身上"
    },
    {
      "start": 17.82,
      "end": 20.22,
      "text": "而是跟他有关理的东西"
    },
    {
      "start": 20.22,
      "end": 21.7,
      "text": "那很大伤"
    },
    {
      "start": 21.7,
      "end": 23.5,
      "text": "他名字的大伤"
    },
    {
      "start": 23.5,
      "end": 25.44,
      "text": "不就是跟他有关理吗"
    },
    {
      "start": 25.44,
      "end": 29.12,
      "text": "我可以在思考什么思考给你们的可称里面"
    },
    {
      "start": 29.12,
      "end": 32.92,
      "text": "加入比我之前被风的使评的内容"
    },
    {
      "start": 32.92,
      "end": 34.72,
      "text": "像被风的外宝"
    },
    {
      "start": 34.72,
      "end": 36.22,
      "text": "那个视频的内容"
    },
    {
      "start": 36.22,
      "end": 39.12,
      "text": "都是没有任何严格版的做给你们"
    },
    {
      "start": 39.12,
      "end": 41.02,
      "text": "但学院谈的想法说的"
    },
    {
      "start": 41.02,
      "end": 41.72,
      "text": "会很敏感"
    },
    {
      "start": 41.72,
      "end": 45.02,
      "text": "但是在自己的圈子发言发觉还好"
    },
    {
      "start": 45.02,
      "end": 46.62,
      "text": "平台上面一定会被风"
    },
    {
      "start": 46.62,
      "end": 49.12,
      "text": "之间号的被风格一个月"
    },
    {
      "start": 49.12,
      "end": 51.52,
      "text": "还有未来你们的客人"
    },
    {
      "start": 51.52,
      "end": 54.12,
      "text": "我想会用不客情是给你们"
    },
    {
      "start": 54.12,
      "end": 56.42,
      "text": "跟自己制裁不方便"
    },
    {
      "start": 56.42,
      "end": 57.62,
      "text": "特别不方便"
    },
    {
      "start": 57.62,
      "end": 59.22,
      "text": "很累看"
    },
    {
      "start": 59.22,
      "end": 61.32,
      "text": "文字以不方便"
    },
    {
      "start": 61.32,
      "end": 62.82,
      "text": "像文字一样"
    },
    {
      "start": 62.82,
      "end": 65.02,
      "text": "学习一个直说"
    },
    {
      "start": 65.02,
      "end": 67.52,
      "text": "我追求一点消败"
    },
    {
      "start": 67.52,
      "end": 70.22,
      "text": "那不客气们代表人事"
    },
    {
      "start": 70.22,
      "end": 73.42,
      "text": "但听到大伦的使考"
    },
    {
      "start": 73.42,
      "end": 76.42,
      "text": "我觉得是不错的一个方向"
    }
  ]
}