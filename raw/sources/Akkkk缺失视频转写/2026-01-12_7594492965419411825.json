{
  "aweme_id": "7594492965419411825",
  "language": "zh",
  "duration": 123.879875,
  "segments": [
    {
      "start": 0.0,
      "end": 3.34,
      "text": "有些小年輕那個思想我要很嚴重的給重述引擎"
    },
    {
      "start": 3.34,
      "end": 5.24,
      "text": "甚至有一點掉毛質也來說"
    },
    {
      "start": 5.24,
      "end": 8.04,
      "text": "哥現在這麼無良玩的風氣"
    },
    {
      "start": 8.04,
      "end": 10.7,
      "text": "甚至如何方批"
    },
    {
      "start": 10.7,
      "end": 12.08,
      "text": "沒有如果所謂"
    },
    {
      "start": 12.08,
      "end": 13.98,
      "text": "你不要隨便不夠霸妝"
    },
    {
      "start": 14.98,
      "end": 16.22,
      "text": "誰先就無聊"
    },
    {
      "start": 16.22,
      "end": 16.98,
      "text": "或是誰"
    },
    {
      "start": 16.98,
      "end": 18.08,
      "text": "他沒有有病"
    },
    {
      "start": 18.08,
      "end": 21.08,
      "text": "會希望自己生活的一個地方"
    },
    {
      "start": 21.08,
      "end": 22.82,
      "text": "生活的這個蹤門"
    },
    {
      "start": 22.82,
      "end": 24.06,
      "text": "也還不好"
    },
    {
      "start": 24.06,
      "end": 24.58,
      "text": "大家會說"
    },
    {
      "start": 24.58,
      "end": 25.98,
      "text": "摔的一個方向去走的"
    },
    {
      "start": 25.98,
      "end": 27.58,
      "text": "沒有人會希望"
    },
    {
      "start": 27.58,
      "end": 28.44,
      "text": "會不是如何"
    },
    {
      "start": 28.44,
      "end": 29.44,
      "text": "有所謂"
    },
    {
      "start": 29.44,
      "end": 30.24,
      "text": "有不是說你會說"
    },
    {
      "start": 30.24,
      "end": 31.54,
      "text": "這個法世界分子"
    },
    {
      "start": 31.54,
      "end": 32.56,
      "text": "真主持人"
    },
    {
      "start": 33.56,
      "end": 34.84,
      "text": "不是這種產品"
    },
    {
      "start": 34.84,
      "end": 36.84,
      "text": "我當時給你們去說"
    },
    {
      "start": 36.84,
      "end": 38.64,
      "text": "未來是什麼要"
    },
    {
      "start": 38.64,
      "end": 41.44,
      "text": "並且存在人類的問題等等"
    },
    {
      "start": 41.44,
      "end": 45.44,
      "text": "是因為我要讓你們有將近的一根真實"
    },
    {
      "start": 45.44,
      "end": 47.94,
      "text": "提前有這樣的一個"
    },
    {
      "start": 47.94,
      "end": 50.24,
      "text": "毛放在哪裡"
    },
    {
      "start": 50.24,
      "end": 51.44,
      "text": "這樣給你"
    },
    {
      "start": 51.44,
      "end": 52.44,
      "text": "清楚的知道"
    },
    {
      "start": 52.44,
      "end": 55.74,
      "text": "你不應該把情恨浪費給搭難搭你的"
    },
    {
      "start": 55.74,
      "end": 57.04,
      "text": "這是比喻"
    },
    {
      "start": 57.04,
      "end": 58.74,
      "text": "自己想法"
    },
    {
      "start": 58.74,
      "end": 60.74,
      "text": "現在不說"
    },
    {
      "start": 60.74,
      "end": 62.74,
      "text": "包括有人先說"
    },
    {
      "start": 62.74,
      "end": 63.74,
      "text": "跟為什麼"
    },
    {
      "start": 63.74,
      "end": 64.74,
      "text": "你以前說的說"
    },
    {
      "start": 64.74,
      "end": 66.74,
      "text": "沒有人認可但是現在大家都"
    },
    {
      "start": 66.74,
      "end": 67.74,
      "text": "感覺到了"
    },
    {
      "start": 67.74,
      "end": 68.74,
      "text": "情緒也上來了"
    },
    {
      "start": 68.74,
      "end": 69.74,
      "text": "你不說了"
    },
    {
      "start": 69.74,
      "end": 73.47,
      "text": "我之前給你們說過多次"
    },
    {
      "start": 73.47,
      "end": 75.47,
      "text": "給你們這樣的一個認真"
    },
    {
      "start": 75.47,
      "end": 77.47,
      "text": "怎樣跟毛是想讓你們"
    },
    {
      "start": 78.47,
      "end": 79.47,
      "text": "夠不住"
    },
    {
      "start": 79.47,
      "end": 80.47,
      "text": "有最好的方法"
    },
    {
      "start": 80.47,
      "end": 81.47,
      "text": "但是你短時間之內"
    },
    {
      "start": 81.47,
      "end": 82.47,
      "text": "人類的最好的方法"
    },
    {
      "start": 82.47,
      "end": 83.47,
      "text": "你做不了"
    },
    {
      "start": 83.47,
      "end": 84.47,
      "text": "你做不到的時候"
    },
    {
      "start": 84.47,
      "end": 86.47,
      "text": "你就夠住"
    },
    {
      "start": 86.47,
      "end": 88.47,
      "text": "我與所住"
    },
    {
      "start": 88.47,
      "end": 90.47,
      "text": "你會活著才有希望"
    },
    {
      "start": 90.47,
      "end": 92.47,
      "text": "而不是讓你們跟著"
    },
    {
      "start": 92.47,
      "end": 94.47,
      "text": "去有情緒"
    },
    {
      "start": 94.47,
      "end": 96.47,
      "text": "你在情緒"
    },
    {
      "start": 96.47,
      "end": 97.47,
      "text": "在其他地方"
    },
    {
      "start": 97.47,
      "end": 99.47,
      "text": "有用在這個地方"
    },
    {
      "start": 99.47,
      "end": 101.47,
      "text": "沒有用"
    },
    {
      "start": 101.47,
      "end": 102.47,
      "text": "明白吧"
    },
    {
      "start": 102.47,
      "end": 103.47,
      "text": "我也不要再給我"
    },
    {
      "start": 103.47,
      "end": 105.47,
      "text": "把你跟什麼合什麼男"
    },
    {
      "start": 105.47,
      "end": 106.47,
      "text": "或者其他的事情"
    },
    {
      "start": 106.47,
      "end": 107.47,
      "text": "要來問我"
    },
    {
      "start": 107.47,
      "end": 109.47,
      "text": "你現在的注意力"
    },
    {
      "start": 109.47,
      "end": 110.47,
      "text": "和時間"
    },
    {
      "start": 110.47,
      "end": 113.47,
      "text": "不應該花在這些上面"
    },
    {
      "start": 113.47,
      "end": 114.47,
      "text": "你要想的是"
    },
    {
      "start": 114.47,
      "end": 116.47,
      "text": "盡快讓自己觸控到"
    },
    {
      "start": 116.47,
      "end": 117.47,
      "text": "最好的解決方式"
    },
    {
      "start": 117.47,
      "end": 118.47,
      "text": "解決方法"
    },
    {
      "start": 118.47,
      "end": 119.47,
      "text": "的那個門檻"
    },
    {
      "start": 119.47,
      "end": 120.47,
      "text": "要出去"
    },
    {
      "start": 120.47,
      "end": 122.47,
      "text": "感受生活"
    },
    {
      "start": 122.47,
      "end": 123.47,
      "text": "想做情緒"
    }
  ]
}