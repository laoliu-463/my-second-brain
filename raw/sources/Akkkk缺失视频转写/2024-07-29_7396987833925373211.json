{
  "aweme_id": "7396987833925373211",
  "language": "zh",
  "duration": 155.459,
  "segments": [
    {
      "start": 0.0,
      "end": 4.04,
      "text": "在我昨天那条视频过后就有分好几个"
    },
    {
      "start": 4.32,
      "end": 5.84,
      "text": "然后我说一下做夜场"
    },
    {
      "start": 5.96,
      "end": 8.76,
      "text": "身材还有人给我刻铺夜场的一刻"
    },
    {
      "start": 8.96,
      "end": 10.84,
      "text": "只为我先任远配置"
    },
    {
      "start": 10.84,
      "end": 13.96,
      "text": "什么够够的一个无需啊"
    },
    {
      "start": 13.96,
      "end": 16.36,
      "text": "你就会自己在海外又有自己的夜场"
    },
    {
      "start": 16.36,
      "end": 17.92,
      "text": "也是你的嘴巴"
    },
    {
      "start": 18.36,
      "end": 20.08,
      "text": "怎么说我还是那句话"
    },
    {
      "start": 20.52,
      "end": 22.44,
      "text": "在我这里很客户"
    },
    {
      "start": 22.84,
      "end": 24.16,
      "text": "没有却做的好"
    },
    {
      "start": 24.44,
      "end": 25.48,
      "text": "或者说说话"
    },
    {
      "start": 25.8,
      "end": 27.0,
      "text": "那我是一个伤的"
    },
    {
      "start": 27.4,
      "end": 30.48,
      "text": "我才会像经济像破壁去看"
    },
    {
      "start": 30.96,
      "end": 33.0,
      "text": "而上代了我赚钱的角度"
    },
    {
      "start": 33.56,
      "end": 34.64,
      "text": "我任何都是好的"
    },
    {
      "start": 34.88,
      "end": 36.36,
      "text": "是要你自己赚转个人家"
    },
    {
      "start": 36.56,
      "end": 37.48,
      "text": "就是说"
    },
    {
      "start": 37.68,
      "end": 40.32,
      "text": "重算你是一个大幼大幼"
    },
    {
      "start": 40.56,
      "end": 42.52,
      "text": "我也会疯你的选择"
    },
    {
      "start": 42.52,
      "end": 43.32,
      "text": "是错的"
    },
    {
      "start": 43.6,
      "end": 44.92,
      "text": "我疯狂念做的这个"
    },
    {
      "start": 44.92,
      "end": 45.64,
      "text": "我疯狂念做"
    },
    {
      "start": 45.8,
      "end": 50.1,
      "text": "是不用做来是大幼大幼"
    },
    {
      "start": 50.3,
      "end": 52.22,
      "text": "成当几个个人是你"
    },
    {
      "start": 52.66,
      "end": 53.34,
      "text": "不说你"
    },
    {
      "start": 53.86,
      "end": 54.82,
      "text": "如果你说"
    },
    {
      "start": 54.98,
      "end": 56.66,
      "text": "那些结果你能成成成成"
    },
    {
      "start": 56.66,
      "end": 58.26,
      "text": "但是你就是为了这一份钱"
    },
    {
      "start": 58.26,
      "end": 59.42,
      "text": "让过来的更多爱"
    },
    {
      "start": 59.58,
      "end": 61.14,
      "text": "那你的选择就是对的"
    },
    {
      "start": 61.34,
      "end": 63.14,
      "text": "甚至最近我身边还很多"
    },
    {
      "start": 63.34,
      "end": 64.34,
      "text": "健身的"
    },
    {
      "start": 64.34,
      "end": 66.06,
      "text": "保护人家是理解过健身交变的"
    },
    {
      "start": 66.06,
      "end": 66.86,
      "text": "再保持酒"
    },
    {
      "start": 66.86,
      "end": 69.26,
      "text": "把你的健体弹勾勾"
    },
    {
      "start": 69.66,
      "end": 70.46,
      "text": "一刻"
    },
    {
      "start": 70.78,
      "end": 71.66,
      "text": "突然就"
    },
    {
      "start": 71.94,
      "end": 72.98,
      "text": "不知道为什么"
    },
    {
      "start": 73.14,
      "end": 74.5,
      "text": "在你全部各地的模糊"
    },
    {
      "start": 74.5,
      "end": 76.38,
      "text": "为健身的人是不断勾勾"
    },
    {
      "start": 76.38,
      "end": 77.7,
      "text": "难得不隐"
    },
    {
      "start": 77.94,
      "end": 78.86,
      "text": "说明说明说明"
    },
    {
      "start": 78.86,
      "end": 81.14,
      "text": "先大叫多更看着物"
    },
    {
      "start": 81.54,
      "end": 83.02,
      "text": "看着你经济"
    },
    {
      "start": 83.22,
      "end": 84.5,
      "text": "而不是去追求一些"
    },
    {
      "start": 84.5,
      "end": 86.14,
      "text": "更多虚无漂亮的东西"
    },
    {
      "start": 86.34,
      "end": 88.06,
      "text": "很多慢慢的也都发现"
    },
    {
      "start": 88.26,
      "end": 89.38,
      "text": "但你的生活"
    },
    {
      "start": 89.38,
      "end": 90.34,
      "text": "你的物质"
    },
    {
      "start": 90.62,
      "end": 92.14,
      "text": "都不到解决的时候"
    },
    {
      "start": 92.34,
      "end": 93.34,
      "text": "那精全层面"
    },
    {
      "start": 93.34,
      "end": 94.7,
      "text": "民愿层面都行"
    },
    {
      "start": 94.7,
      "end": 96.5,
      "text": "就显得那么长百的力"
    },
    {
      "start": 96.7,
      "end": 98.22,
      "text": "所以不要更多要使得"
    },
    {
      "start": 98.22,
      "end": 99.66,
      "text": "绝心不绝心"
    },
    {
      "start": 99.66,
      "end": 101.86,
      "text": "全是我们必须会表达我们法徒"
    },
    {
      "start": 101.86,
      "end": 103.06,
      "text": "拿冒出来的"
    },
    {
      "start": 103.26,
      "end": 104.7,
      "text": "不只用你自己知道"
    },
    {
      "start": 105.02,
      "end": 106.14,
      "text": "是你需要什么"
    },
    {
      "start": 106.66,
      "end": 108.38,
      "text": "你需要想你就解决戒"
    },
    {
      "start": 108.98,
      "end": 109.7,
      "text": "但你解决戒"
    },
    {
      "start": 109.7,
      "end": 110.9,
      "text": "你需要散个室"
    },
    {
      "start": 110.9,
      "end": 112.46,
      "text": "再慢慢的室居居"
    },
    {
      "start": 112.46,
      "end": 113.46,
      "text": "没有人有资格"
    },
    {
      "start": 113.46,
      "end": 114.82,
      "text": "分余的选择出"
    },
    {
      "start": 114.82,
      "end": 115.86,
      "text": "就算你的"
    },
    {
      "start": 116.26,
      "end": 117.38,
      "text": "选择的这个"
    },
    {
      "start": 117.62,
      "end": 119.14,
      "text": "工作或者说是"
    },
    {
      "start": 119.14,
      "end": 120.18,
      "text": "写不修"
    },
    {
      "start": 120.18,
      "end": 121.22,
      "text": "不开的点"
    },
    {
      "start": 121.22,
      "end": 121.66,
      "text": "可"
    },
    {
      "start": 121.66,
      "end": 122.58,
      "text": "又怎么样呢"
    },
    {
      "start": 122.78,
      "end": 124.06,
      "text": "并不是每一个人"
    },
    {
      "start": 124.46,
      "end": 126.06,
      "text": "天成都能用越来越多的物质"
    },
    {
      "start": 126.26,
      "end": 127.02,
      "text": "何况每个人"
    },
    {
      "start": 127.02,
      "end": 128.42,
      "text": "出生都已经注定了"
    },
    {
      "start": 128.42,
      "end": 130.42,
      "text": "生活在一个最大的差距之中"
    },
    {
      "start": 130.42,
      "end": 132.38,
      "text": "每次在权表告明白的之间"
    },
    {
      "start": 132.42,
      "end": 133.86,
      "text": "你到底想要什么"
    },
    {
      "start": 133.86,
      "end": 135.34,
      "text": "如果你现在想要的就是"
    },
    {
      "start": 135.34,
      "end": 136.74,
      "text": "一做一个资本之内"
    },
    {
      "start": 136.74,
      "end": 138.42,
      "text": "做一个原始的鸡脸"
    },
    {
      "start": 138.42,
      "end": 139.74,
      "text": "那不得受不断"
    },
    {
      "start": 139.74,
      "end": 140.62,
      "text": "就好了"
    },
    {
      "start": 140.94,
      "end": 142.62,
      "text": "没有谁的资本鸡脸"
    },
    {
      "start": 142.62,
      "end": 143.62,
      "text": "出细"
    },
    {
      "start": 143.86,
      "end": 144.86,
      "text": "是干净的"
    },
    {
      "start": 145.86,
      "end": 146.7,
      "text": "至于很多"
    },
    {
      "start": 146.7,
      "end": 147.98,
      "text": "我是绵男同胞"
    },
    {
      "start": 147.98,
      "end": 148.62,
      "text": "健身的"
    },
    {
      "start": 148.62,
      "end": 149.3,
      "text": "为什么跑去"
    },
    {
      "start": 149.3,
      "end": 150.3,
      "text": "当狗狗的"
    },
    {
      "start": 150.3,
      "end": 151.9,
      "text": "我去调演一下"
    },
    {
      "start": 151.9,
      "end": 152.9,
      "text": "市场看一看"
    },
    {
      "start": 152.9,
      "end": 154.1,
      "text": "是咱们个山"
    },
    {
      "start": 154.38,
      "end": 155.38,
      "text": "我再来说"
    }
  ]
}