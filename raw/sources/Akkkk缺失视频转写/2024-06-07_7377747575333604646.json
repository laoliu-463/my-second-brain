{
  "aweme_id": "7377747575333604646",
  "language": "zh",
  "duration": 139.06575,
  "segments": [
    {
      "start": 0.0,
      "end": 2.3,
      "text": "一些虚难愿你怎么去摆脱这种人"
    },
    {
      "start": 2.3,
      "end": 3.84,
      "text": "自己关系中的那一号"
    },
    {
      "start": 3.84,
      "end": 7.18,
      "text": "第一就是不要对任何人有到的期待"
    },
    {
      "start": 7.18,
      "end": 8.96,
      "text": "不算你们看没看起云年"
    },
    {
      "start": 8.96,
      "end": 10.5,
      "text": "因为有个角色"
    },
    {
      "start": 10.5,
      "end": 12.02,
      "text": "这个人还要参一本"
    },
    {
      "start": 12.02,
      "end": 13.06,
      "text": "那个人还要参一本"
    },
    {
      "start": 13.06,
      "end": 15.86,
      "text": "最好还善要被参一本"
    },
    {
      "start": 15.86,
      "end": 17.4,
      "text": "这个时候又不得不说到"
    },
    {
      "start": 17.4,
      "end": 18.94,
      "text": "完全有一个重量"
    },
    {
      "start": 18.94,
      "end": 19.96,
      "text": "就在国伐"
    },
    {
      "start": 19.96,
      "end": 22.78,
      "text": "用现在的主流主观思想来看待他"
    },
    {
      "start": 22.78,
      "end": 23.56,
      "text": "就是"
    },
    {
      "start": 23.56,
      "end": 26.12,
      "text": "学史人陪你做事"
    },
    {
      "start": 26.12,
      "end": 26.88,
      "text": "各方面"
    },
    {
      "start": 26.88,
      "end": 28.68,
      "text": "肯定都是一榜样来形容"
    },
    {
      "start": 28.68,
      "end": 30.46,
      "text": "来看待"
    },
    {
      "start": 30.46,
      "end": 33.04,
      "text": "但是他一开始做关系的做并不好"
    },
    {
      "start": 33.04,
      "end": 34.32,
      "text": "八面数的"
    },
    {
      "start": 34.32,
      "end": 35.08,
      "text": "为什么"
    },
    {
      "start": 35.08,
      "end": 37.64,
      "text": "他不仅对自己有一些到的约书"
    },
    {
      "start": 37.64,
      "end": 39.7,
      "text": "他还对别人有到的约书"
    },
    {
      "start": 39.7,
      "end": 41.48,
      "text": "就跟电视巨疗"
    },
    {
      "start": 41.48,
      "end": 43.54,
      "text": "今天这个人做风不好参一本"
    },
    {
      "start": 43.54,
      "end": 45.32,
      "text": "明天参那个人一本"
    },
    {
      "start": 45.32,
      "end": 46.86,
      "text": "是什么又夸张到"
    },
    {
      "start": 46.86,
      "end": 48.4,
      "text": "去参皇上"
    },
    {
      "start": 48.4,
      "end": 49.94,
      "text": "那他后面一开始反省"
    },
    {
      "start": 49.94,
      "end": 51.72,
      "text": "反省官一会还这凌务到了"
    },
    {
      "start": 51.72,
      "end": 52.74,
      "text": "大楼飞楼"
    },
    {
      "start": 52.74,
      "end": 54.02,
      "text": "只刚不干到"
    },
    {
      "start": 54.02,
      "end": 56.1,
      "text": "最后就输立了一天下"
    },
    {
      "start": 56.1,
      "end": 59.26,
      "text": "这只是教育天下这只刚的作人原子"
    },
    {
      "start": 59.26,
      "end": 61.42,
      "text": "什么意思呢?任何事情"
    },
    {
      "start": 61.42,
      "end": 62.82,
      "text": "只要结果是好的"
    },
    {
      "start": 62.82,
      "end": 65.26,
      "text": "过程中出现的一些下子"
    },
    {
      "start": 65.26,
      "end": 67.5,
      "text": "都没有问题都没关系"
    },
    {
      "start": 67.5,
      "end": 69.3,
      "text": "别人做事的方式和说的短"
    },
    {
      "start": 69.3,
      "end": 70.54,
      "text": "就算自己不认可"
    },
    {
      "start": 70.54,
      "end": 71.7,
      "text": "也不顾问"
    },
    {
      "start": 71.7,
      "end": 73.3,
      "text": "别人在后面调设坑"
    },
    {
      "start": 73.3,
      "end": 74.3,
      "text": "就认则"
    },
    {
      "start": 74.3,
      "end": 75.94,
      "text": "别人在后面统刀子"
    },
    {
      "start": 75.94,
      "end": 78.18,
      "text": "不是知名上也不追究"
    },
    {
      "start": 78.18,
      "end": 80.3,
      "text": "调深心你老师要一聊"
    },
    {
      "start": 80.3,
      "end": 82.18,
      "text": "过程结果时间一长"
    },
    {
      "start": 82.18,
      "end": 83.14,
      "text": "所有人都发现"
    },
    {
      "start": 83.14,
      "end": 84.74,
      "text": "能够放灯变了"
    },
    {
      "start": 84.74,
      "end": 87.06,
      "text": "不像个思维影斗说的扎人"
    },
    {
      "start": 87.06,
      "end": 88.74,
      "text": "99只他身边的敌人"
    },
    {
      "start": 88.74,
      "end": 90.46,
      "text": "慢慢的一都消失了"
    },
    {
      "start": 90.46,
      "end": 92.5,
      "text": "你们的心思就是想着怎么去"
    },
    {
      "start": 92.5,
      "end": 93.94,
      "text": "为皇上排游简单"
    },
    {
      "start": 93.94,
      "end": 96.74,
      "text": "99只在皇上心中的心灯和威望"
    },
    {
      "start": 96.74,
      "end": 98.62,
      "text": "也就慢慢建立起来了"
    },
    {
      "start": 98.62,
      "end": 100.86,
      "text": "但你懂得人性皆自死"
    },
    {
      "start": 100.86,
      "end": 103.3,
      "text": "每个人做的每一件事情说的每一句话都是"
    },
    {
      "start": 103.3,
      "end": 105.7,
      "text": "我有自己的利益去开展的"
    },
    {
      "start": 105.7,
      "end": 107.62,
      "text": "你自然而然也就失化来了"
    },
    {
      "start": 107.62,
      "end": 109.34,
      "text": "要你对任有道德期望"
    },
    {
      "start": 109.34,
      "end": 110.54,
      "text": "一觉逼受伤"
    },
    {
      "start": 110.54,
      "end": 112.26,
      "text": "比如说一些调谋男人说的"
    },
    {
      "start": 112.26,
      "end": 113.1,
      "text": "我是爱你"
    },
    {
      "start": 113.1,
      "end": 115.38,
      "text": "我是爱你一个人玩你一辈子"
    },
    {
      "start": 115.38,
      "end": 116.82,
      "text": "或者说一些女人说的"
    },
    {
      "start": 116.82,
      "end": 119.46,
      "text": "不认识平均什么样的困难"
    },
    {
      "start": 119.46,
      "end": 122.0,
      "text": "不是批划"
    },
    {
      "start": 122.0,
      "end": 123.4,
      "text": "这都是同话"
    },
    {
      "start": 123.4,
      "end": 124.6,
      "text": "在利益面前"
    },
    {
      "start": 124.6,
      "end": 125.88,
      "text": "如果不是"
    },
    {
      "start": 125.88,
      "end": 128.2,
      "text": "只能说明这个利益还不够大"
    },
    {
      "start": 128.2,
      "end": 130.04,
      "text": "我不是让你不讲道德"
    },
    {
      "start": 130.04,
      "end": 132.92,
      "text": "我是让你别希望别人对你道德"
    },
    {
      "start": 132.92,
      "end": 135.92,
      "text": "你要知道道德约束自己是真道的"
    },
    {
      "start": 135.92,
      "end": 138.96,
      "text": "但用道德约束别人是真不到的"
    }
  ]
}