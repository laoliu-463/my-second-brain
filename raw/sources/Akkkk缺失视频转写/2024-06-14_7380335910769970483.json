{
  "aweme_id": "7380335910769970483",
  "language": "zh",
  "duration": 134.42175,
  "segments": [
    {
      "start": 0.0,
      "end": 2.0,
      "text": "很多跟我資訊情感人女的"
    },
    {
      "start": 2.0,
      "end": 4.5,
      "text": "我發現你不會多一個聰明的女人"
    },
    {
      "start": 4.5,
      "end": 6.5,
      "text": "什麼是一個聰明的女人"
    },
    {
      "start": 6.5,
      "end": 9.0,
      "text": "就是看破不說不破"
    },
    {
      "start": 9.0,
      "end": 11.0,
      "text": "不該你管的你就別管"
    },
    {
      "start": 11.0,
      "end": 13.5,
      "text": "你自己去做你自己的事情不就好了"
    },
    {
      "start": 13.5,
      "end": 16.0,
      "text": "去做你自己開心快樂的事情"
    },
    {
      "start": 16.0,
      "end": 17.5,
      "text": "很多的船的日"
    },
    {
      "start": 17.5,
      "end": 19.0,
      "text": "我什麼都要管"
    },
    {
      "start": 19.0,
      "end": 20.5,
      "text": "我什麼都想控制"
    },
    {
      "start": 20.5,
      "end": 22.5,
      "text": "其實你知道對方的條件的各方面"
    },
    {
      "start": 22.5,
      "end": 24.0,
      "text": "都比你好很多"
    },
    {
      "start": 24.0,
      "end": 27.0,
      "text": "你還是想要去通過這種控制"
    },
    {
      "start": 27.0,
      "end": 28.5,
      "text": "或者說是後期的一些"
    },
    {
      "start": 28.5,
      "end": 30.5,
      "text": "道德綁架來去綁架給人"
    },
    {
      "start": 30.5,
      "end": 33.0,
      "text": "進一步一會開始無中身有"
    },
    {
      "start": 33.0,
      "end": 34.5,
      "text": "還有一次一抓到那些主思嘛"
    },
    {
      "start": 34.5,
      "end": 36.5,
      "text": "自己還覺得自己很聰明"
    },
    {
      "start": 36.5,
      "end": 37.5,
      "text": "就很醜了"
    },
    {
      "start": 37.5,
      "end": 38.5,
      "text": "好吧"
    },
    {
      "start": 38.5,
      "end": 40.5,
      "text": "你真正聰明是什麼"
    },
    {
      "start": 40.5,
      "end": 42.5,
      "text": "不會去過多的感受對方"
    },
    {
      "start": 42.5,
      "end": 43.5,
      "text": "因為他知道"
    },
    {
      "start": 43.5,
      "end": 45.0,
      "text": "自己的對象是高價值的"
    },
    {
      "start": 45.0,
      "end": 47.0,
      "text": "想管也管不住"
    },
    {
      "start": 47.0,
      "end": 48.0,
      "text": "你能清理的話"
    },
    {
      "start": 48.0,
      "end": 49.5,
      "text": "他身邊那些"
    },
    {
      "start": 49.5,
      "end": 50.5,
      "text": "接種而知"
    },
    {
      "start": 50.5,
      "end": 52.5,
      "text": "封用而知的小秘封的"
    },
    {
      "start": 52.5,
      "end": 53.5,
      "text": "你清到什麼時候"
    },
    {
      "start": 53.5,
      "end": 55.5,
      "text": "想太多了吧"
    },
    {
      "start": 55.5,
      "end": 56.5,
      "text": "那"
    },
    {
      "start": 56.5,
      "end": 58.5,
      "text": "在一張感情關係裡面"
    },
    {
      "start": 58.5,
      "end": 60.5,
      "text": "擁有絕對的高價值"
    },
    {
      "start": 60.5,
      "end": 62.5,
      "text": "以及財力的地方"
    },
    {
      "start": 62.5,
      "end": 63.5,
      "text": "絕對的假方存在"
    },
    {
      "start": 63.5,
      "end": 64.5,
      "text": "裏則"
    },
    {
      "start": 64.5,
      "end": 65.5,
      "text": "就很多粉絲會問我"
    },
    {
      "start": 65.5,
      "end": 66.5,
      "text": "會跟你會這種"
    },
    {
      "start": 66.5,
      "end": 68.5,
      "text": "感性下面的問題嗎"
    },
    {
      "start": 68.5,
      "end": 69.5,
      "text": "說實話"
    },
    {
      "start": 69.5,
      "end": 71.5,
      "text": "不全愛戰士"
    },
    {
      "start": 71.5,
      "end": 72.5,
      "text": "在一張關係裡面"
    },
    {
      "start": 72.5,
      "end": 74.5,
      "text": "我肯定可以保安"
    },
    {
      "start": 74.5,
      "end": 75.5,
      "text": "分擺的保證"
    },
    {
      "start": 75.5,
      "end": 76.5,
      "text": "不是全愛戰士"
    },
    {
      "start": 76.5,
      "end": 77.5,
      "text": "但是分手以後"
    },
    {
      "start": 77.5,
      "end": 79.5,
      "text": "就會很砸頭"
    },
    {
      "start": 79.5,
      "end": 80.5,
      "text": "不會有那麼多人"
    },
    {
      "start": 80.5,
      "end": 81.5,
      "text": "什麼情緒"
    },
    {
      "start": 81.5,
      "end": 82.5,
      "text": "或者說是"
    },
    {
      "start": 82.5,
      "end": 84.5,
      "text": "好死不死的愛不愛人"
    },
    {
      "start": 84.5,
      "end": 85.5,
      "text": "不會"
    },
    {
      "start": 85.5,
      "end": 87.5,
      "text": "我們這種類型的人物觀察過"
    },
    {
      "start": 87.5,
      "end": 89.5,
      "text": "我們可以很愛對方"
    },
    {
      "start": 89.5,
      "end": 90.5,
      "text": "但是結束以後"
    },
    {
      "start": 90.5,
      "end": 92.5,
      "text": "我們也可以很快抽出來"
    },
    {
      "start": 92.5,
      "end": 93.5,
      "text": "那"
    },
    {
      "start": 93.5,
      "end": 94.5,
      "text": "為什麼可以這麼做"
    },
    {
      "start": 94.5,
      "end": 96.5,
      "text": "就選擇太多"
    },
    {
      "start": 96.5,
      "end": 98.5,
      "text": "就被的也會很多"
    },
    {
      "start": 98.5,
      "end": 99.5,
      "text": "你在現實中"
    },
    {
      "start": 99.5,
      "end": 100.5,
      "text": "你有條件"
    },
    {
      "start": 100.5,
      "end": 101.5,
      "text": "你有價值"
    },
    {
      "start": 101.5,
      "end": 102.5,
      "text": "你肯定是不會缺的"
    },
    {
      "start": 102.5,
      "end": 105.5,
      "text": "你要搞清楚這種底層原理"
    },
    {
      "start": 105.5,
      "end": 106.5,
      "text": "不會說非他不可"
    },
    {
      "start": 106.5,
      "end": 108.5,
      "text": "或是非這個不可"
    },
    {
      "start": 108.5,
      "end": 109.5,
      "text": "那"
    },
    {
      "start": 109.5,
      "end": 110.5,
      "text": "是小說"
    },
    {
      "start": 110.5,
      "end": 113.5,
      "text": "我一定要學會對我一個聰明的女人"
    },
    {
      "start": 113.5,
      "end": 115.5,
      "text": "不要去干涉對方"
    },
    {
      "start": 115.5,
      "end": 116.5,
      "text": "不要去廣對方"
    },
    {
      "start": 116.5,
      "end": 118.5,
      "text": "不要用這種思想"
    },
    {
      "start": 118.5,
      "end": 119.5,
      "text": "你要把你做的經歷"
    },
    {
      "start": 119.5,
      "end": 122.5,
      "text": "花在提高自己的心理上"
    },
    {
      "start": 122.5,
      "end": 123.5,
      "text": "你又秀了"
    },
    {
      "start": 123.5,
      "end": 125.5,
      "text": "你吸引住對方"
    },
    {
      "start": 125.5,
      "end": 126.5,
      "text": "對方自然而然"
    },
    {
      "start": 126.5,
      "end": 127.5,
      "text": "他會留下來的"
    },
    {
      "start": 127.5,
      "end": 128.5,
      "text": "你靠管"
    },
    {
      "start": 128.5,
      "end": 129.5,
      "text": "你靠控制"
    },
    {
      "start": 129.5,
      "end": 131.5,
      "text": "你在內部累"
    },
    {
      "start": 131.5,
      "end": 132.5,
      "text": "你在想要什麼"
    }
  ]
}