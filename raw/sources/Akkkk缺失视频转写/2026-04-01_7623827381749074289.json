  "segments": [
    {
      "start": 0.0,
      "end": 4.04,
      "text": "说两个事情 第一个就是这种小看"
    },
    {
      "start": 5.04,
      "end": 6.68,
      "text": "我也不知道你关注我是为什么"
    },
    {
      "start": 6.68,
      "end": 9.84,
