{
  "aweme_id": "7596327728018866041",
  "language": "zh",
  "duration": 162.7500625,
  "segments": [
    {
      "start": 0.0,
      "end": 2.0,
      "text": "昨晚的视频被谈了"
    },
    {
      "start": 2.0,
      "end": 4.4,
      "text": "本来说视频应该是图文"
    },
    {
      "start": 4.4,
      "end": 8.4,
      "text": "一旦给你们说一件什么本质东西就不得了"
    },
    {
      "start": 8.4,
      "end": 9.4,
      "text": "没有法"
    },
    {
      "start": 9.4,
      "end": 10.8,
      "text": "只不说了"
    },
    {
      "start": 10.8,
      "end": 16.8,
      "text": "其次最近前有过暂时还险后有什么浪贵"
    },
    {
      "start": 16.8,
      "end": 19.2,
      "text": "一些人或者是认识了"
    },
    {
      "start": 19.2,
      "end": 19.8,
      "text": "有意义"
    },
    {
      "start": 19.8,
      "end": 22.4,
      "text": "忘记了一个重要的事情"
    },
    {
      "start": 22.4,
      "end": 24.2,
      "text": "以前就无数次说过了"
    },
    {
      "start": 24.2,
      "end": 27.6,
      "text": "尊重了每一次我和他们进"
    },
    {
      "start": 27.6,
      "end": 29.0,
      "text": "这东西不但是说给别人"
    },
    {
      "start": 29.0,
      "end": 30.4,
      "text": "也说给你们自己"
    },
    {
      "start": 30.4,
      "end": 30.8,
      "text": "干嘛"
    },
    {
      "start": 30.8,
      "end": 31.8,
      "text": "算是自己"
    },
    {
      "start": 31.8,
      "end": 33.8,
      "text": "也不变彻自己"
    },
    {
      "start": 33.8,
      "end": 36.2,
      "text": "想想要见一个视频里面已经说了"
    },
    {
      "start": 36.2,
      "end": 36.8,
      "text": "不许"
    },
    {
      "start": 36.8,
      "end": 37.8,
      "text": "让你的生活"
    },
    {
      "start": 37.8,
      "end": 39.6,
      "text": "我会说你的未来"
    },
    {
      "start": 39.6,
      "end": 41.0,
      "text": "是你自己去感受"
    },
    {
      "start": 41.0,
      "end": 42.2,
      "text": "你自己去做的"
    },
    {
      "start": 42.2,
      "end": 43.0,
      "text": "不是有谁"
    },
    {
      "start": 43.0,
      "end": 43.6,
      "text": "特谁"
    },
    {
      "start": 43.6,
      "end": 44.2,
      "text": "那谁"
    },
    {
      "start": 44.2,
      "end": 47.0,
      "text": "或者说是模模做的是什么人"
    },
    {
      "start": 47.0,
      "end": 48.0,
      "text": "给你说了"
    },
    {
      "start": 48.0,
      "end": 50.4,
      "text": "就可以了"
    },
    {
      "start": 50.4,
      "end": 51.8,
      "text": "来"
    },
    {
      "start": 51.8,
      "end": 53.4,
      "text": "就是"
    },
    {
      "start": 53.4,
      "end": 54.4,
      "text": "这里"
    },
    {
      "start": 54.4,
      "end": 55.4,
      "text": "这个乃本的人"
    },
    {
      "start": 55.4,
      "end": 57.4,
      "text": "给自己的居点"
    },
    {
      "start": 57.4,
      "end": 59.6,
      "text": "努力高闯找的一个合理性"
    },
    {
      "start": 59.6,
      "end": 60.4,
      "text": "为什么"
    },
    {
      "start": 60.4,
      "end": 61.6,
      "text": "因为"
    },
    {
      "start": 61.6,
      "end": 62.8,
      "text": "说得很听一点"
    },
    {
      "start": 62.8,
      "end": 64.6,
      "text": "就国内自己都没去的过程"
    },
    {
      "start": 64.6,
      "end": 65.2,
      "text": "几个地方"
    },
    {
      "start": 65.2,
      "end": 66.2,
      "text": "那个行李中很打开"
    },
    {
      "start": 66.2,
      "end": 67.2,
      "text": "看看那个"
    },
    {
      "start": 67.2,
      "end": 69.2,
      "text": "去过的地方那个途律"
    },
    {
      "start": 69.2,
      "end": 71.2,
      "text": "途没有几条线"
    },
    {
      "start": 72.4,
      "end": 73.6,
      "text": "然后听到这些所谓的"
    },
    {
      "start": 73.6,
      "end": 74.8,
      "text": "有人回来有什么说一些"
    },
    {
      "start": 74.8,
      "end": 76.4,
      "text": "真相而说一些"
    },
    {
      "start": 76.4,
      "end": 78.2,
      "text": "触换到一只点东西"
    },
    {
      "start": 78.2,
      "end": 80.0,
      "text": "就觉得就是那样子"
    },
    {
      "start": 81.0,
      "end": 82.2,
      "text": "却忘记了"
    },
    {
      "start": 82.2,
      "end": 84.0,
      "text": "虽然你是一只挖"
    },
    {
      "start": 84.0,
      "end": 85.6,
      "text": "你在那口间里面"
    },
    {
      "start": 85.6,
      "end": 86.8,
      "text": "我像熊面一样"
    },
    {
      "start": 86.8,
      "end": 87.84,
      "text": "在上面飞"
    },
    {
      "start": 87.84,
      "end": 88.64,
      "text": "在那里飞"
    },
    {
      "start": 88.64,
      "end": 90.2,
      "text": "但是牛腿的吗"
    },
    {
      "start": 90.2,
      "end": 92.4,
      "text": "你可以跳出这个节的吗"
    },
    {
      "start": 92.4,
      "end": 94.0,
      "text": "反而是不要为自己的"
    },
    {
      "start": 94.0,
      "end": 96.4,
      "text": "无力"
    },
    {
      "start": 96.4,
      "end": 97.12,
      "text": "落落"
    },
    {
      "start": 97.12,
      "end": 98.4,
      "text": "切我"
    },
    {
      "start": 98.4,
      "end": 99.88,
      "text": "这个时候突然出现一个"
    },
    {
      "start": 99.88,
      "end": 103.99,
      "text": "能让你这些点和立化"
    },
    {
      "start": 103.99,
      "end": 104.99,
      "text": "或者是"
    },
    {
      "start": 104.99,
      "end": 106.39,
      "text": "我信息一样"
    },
    {
      "start": 106.39,
      "end": 109.65,
      "text": "你就"
    },
    {
      "start": 109.65,
      "end": 111.05,
      "text": "脑子里面边走了"
    },
    {
      "start": 111.05,
      "end": 112.45,
      "text": "不存在的"
    },
    {
      "start": 112.45,
      "end": 114.65,
      "text": "没有感受过的东西"
    },
    {
      "start": 114.65,
      "end": 115.45,
      "text": "自己去感受完"
    },
    {
      "start": 115.45,
      "end": 119.41,
      "text": "自己说过很多次"
    },
    {
      "start": 119.41,
      "end": 120.41,
      "text": "自己的东西没有什么好人"
    },
    {
      "start": 120.41,
      "end": 123.44,
      "text": "不况人家周门那里"
    },
    {
      "start": 123.44,
      "end": 124.84,
      "text": "人家周门主现在跳出来"
    },
    {
      "start": 124.84,
      "end": 126.24,
      "text": "说了一些啥"
    },
    {
      "start": 126.24,
      "end": 127.84,
      "text": "这个视频现在也蛮好的"
    },
    {
      "start": 127.84,
      "end": 129.04,
      "text": "对人家都在传"
    },
    {
      "start": 129.04,
      "end": 130.04,
      "text": "也被抬得蛮多"
    }
  ]
}