{
  "aweme_id": "7532839269434920251",
  "language": "zh",
  "duration": 175.4731875,
  "segments": [
    {
      "start": 0.05,
      "end": 2.05,
      "text": "我说啥来人"
    },
    {
      "start": 2.05,
      "end": 4.65,
      "text": "证明不是参贵者"
    },
    {
      "start": 4.65,
      "end": 6.45,
      "text": "我说是关联者"
    },
    {
      "start": 6.45,
      "end": 9.05,
      "text": "怎么会知道开会的信息"
    },
    {
      "start": 9.05,
      "end": 11.45,
      "text": "所以不用猜我是谁"
    },
    {
      "start": 11.45,
      "end": 13.05,
      "text": "或者说我"
    },
    {
      "start": 13.05,
      "end": 14.45,
      "text": "等等你怎么样"
    },
    {
      "start": 14.45,
      "end": 16.05,
      "text": "放到现实中"
    },
    {
      "start": 16.05,
      "end": 18.05,
      "text": "本来就不在一个层极下"
    },
    {
      "start": 18.05,
      "end": 20.05,
      "text": "过好你的口日子"
    },
    {
      "start": 20.05,
      "end": 21.05,
      "text": "要不是朋友建设"
    },
    {
      "start": 21.05,
      "end": 23.05,
      "text": "现在基本上是不会工作了"
    },
    {
      "start": 23.05,
      "end": 25.52,
      "text": "投资的事"
    },
    {
      "start": 25.52,
      "end": 26.52,
      "text": "钱就说过"
    },
    {
      "start": 26.52,
      "end": 28.52,
      "text": "但还是没有变"
    },
    {
      "start": 28.52,
      "end": 30.52,
      "text": "马上26年了"
    },
    {
      "start": 30.52,
      "end": 32.52,
      "text": "把主流投资判拉出来"
    },
    {
      "start": 32.52,
      "end": 34.52,
      "text": "在一起就要留"
    },
    {
      "start": 34.52,
      "end": 36.52,
      "text": "还是老样子"
    },
    {
      "start": 36.52,
      "end": 38.52,
      "text": "什么风红权"
    },
    {
      "start": 38.52,
      "end": 39.52,
      "text": "骨权"
    },
    {
      "start": 39.52,
      "end": 40.52,
      "text": "这一权"
    },
    {
      "start": 40.52,
      "end": 43.52,
      "text": "通通都是战严草"
    },
    {
      "start": 43.52,
      "end": 45.52,
      "text": "最终的目的"
    },
    {
      "start": 45.52,
      "end": 46.52,
      "text": "从始之中"
    },
    {
      "start": 46.52,
      "end": 47.52,
      "text": "只有四个字"
    },
    {
      "start": 47.52,
      "end": 48.52,
      "text": "上市退出"
    },
    {
      "start": 48.52,
      "end": 50.52,
      "text": "不上就退出回够"
    },
    {
      "start": 50.52,
      "end": 52.52,
      "text": "上又再这么下雨"
    },
    {
      "start": 52.52,
      "end": 53.52,
      "text": "上又"
    },
    {
      "start": 53.52,
      "end": 54.52,
      "text": "那四个大子"
    },
    {
      "start": 54.52,
      "end": 56.52,
      "text": "框框往哪一方"
    },
    {
      "start": 56.52,
      "end": 57.52,
      "text": "下又切子"
    },
    {
      "start": 57.52,
      "end": 58.52,
      "text": "那干嘛"
    },
    {
      "start": 58.52,
      "end": 59.52,
      "text": "只能一门心死的"
    },
    {
      "start": 59.52,
      "end": 61.52,
      "text": "做作词标"
    },
    {
      "start": 61.52,
      "end": 63.52,
      "text": "刷交易流水"
    },
    {
      "start": 63.52,
      "end": 65.52,
      "text": "时则引力"
    },
    {
      "start": 65.52,
      "end": 66.52,
      "text": "一吐血"
    },
    {
      "start": 66.52,
      "end": 67.52,
      "text": "鸡骨权华"
    },
    {
      "start": 67.52,
      "end": 69.52,
      "text": "以前船的确实是华"
    },
    {
      "start": 69.52,
      "end": 70.52,
      "text": "现在船的是血"
    },
    {
      "start": 70.52,
      "end": 72.52,
      "text": "关键是谁街盘的"
    },
    {
      "start": 72.52,
      "end": 73.52,
      "text": "游船"
    },
    {
      "start": 73.52,
      "end": 76.52,
      "text": "大家都已经认了一些"
    },
    {
      "start": 76.52,
      "end": 77.52,
      "text": "都留了一些"
    },
    {
      "start": 77.52,
      "end": 79.52,
      "text": "那没留的呢"
    },
    {
      "start": 79.52,
      "end": 81.52,
      "text": "我们不都已经到月家入了"
    },
    {
      "start": 81.52,
      "end": 82.52,
      "text": "中船"
    },
    {
      "start": 82.52,
      "end": 83.52,
      "text": "下行的时候"
    },
    {
      "start": 83.52,
      "end": 84.52,
      "text": "可没有中船"
    },
    {
      "start": 84.52,
      "end": 86.52,
      "text": "骨头的楼船"
    },
    {
      "start": 86.52,
      "end": 87.52,
      "text": "还在看"
    },
    {
      "start": 87.52,
      "end": 89.52,
      "text": "现在真正船舟的项目"
    },
    {
      "start": 89.52,
      "end": 92.52,
      "text": "或者说是个替以后的企业要"
    },
    {
      "start": 92.52,
      "end": 95.52,
      "text": "更容易被现金牛头子所欣"
    },
    {
      "start": 95.52,
      "end": 97.52,
      "text": "我们船分辆了"
    },
    {
      "start": 97.52,
      "end": 98.52,
      "text": "游化配套"
    },
    {
      "start": 98.52,
      "end": 100.52,
      "text": "跟你分钱分仗"
    },
    {
      "start": 100.52,
      "end": 103.52,
      "text": "所以一句环境变一变"
    },
    {
      "start": 103.52,
      "end": 105.52,
      "text": "变老一没心思"
    },
    {
      "start": 105.52,
      "end": 106.52,
      "text": "只想着那两个字"
    },
    {
      "start": 106.52,
      "end": 110.06,
      "text": "广级两"
    },
    {
      "start": 110.06,
      "end": 111.06,
      "text": "高重强"
    },
    {
      "start": 111.06,
      "end": 112.06,
      "text": "广纯我们"
    },
    {
      "start": 112.06,
      "end": 114.06,
      "text": "大部分没脑子"
    },
    {
      "start": 114.06,
      "end": 115.06,
      "text": "那些黑子"
    },
    {
      "start": 115.06,
      "end": 117.06,
      "text": "说两心理"
    },
    {
      "start": 118.06,
      "end": 119.06,
      "text": "看到没有"
    },
    {
      "start": 119.06,
      "end": 121.06,
      "text": "还没我的狗生叫狗"
    },
    {
      "start": 122.06,
      "end": 124.06,
      "text": "多一大部分粉丝"
    },
    {
      "start": 124.06,
      "end": 126.06,
      "text": "你们知道我传达这些信息"
    },
    {
      "start": 126.06,
      "end": 128.06,
      "text": "的目的是让你外报不好自此"
    },
    {
      "start": 128.06,
      "end": 130.06,
      "text": "就够不用去跟那些乐资源"
    },
    {
      "start": 130.06,
      "end": 131.06,
      "text": "差深对话"
    },
    {
      "start": 131.06,
      "end": 132.06,
      "text": "因为你会发现"
    },
    {
      "start": 132.06,
      "end": 134.06,
      "text": "他们会像风狗一样"
    },
    {
      "start": 134.06,
      "end": 136.06,
      "text": "刀处乱药"
    },
    {
      "start": 136.06,
      "end": 139.06,
      "text": "还以为那影响到谁呢"
    },
    {
      "start": 141.06,
      "end": 144.06,
      "text": "我站在这样的高度"
    },
    {
      "start": 145.06,
      "end": 148.06,
      "text": "看是我想受生活"
    },
    {
      "start": 148.06,
      "end": 151.06,
      "text": "而他只是在下面"
    },
    {
      "start": 151.06,
      "end": 152.06,
      "text": "养头看我"
    },
    {
      "start": 152.06,
      "end": 153.06,
      "text": "我第一头看他"
    },
    {
      "start": 153.06,
      "end": 155.06,
      "text": "他以为他能影响我"
    },
    {
      "start": 155.06,
      "end": 157.06,
      "text": "这不传乐资源"
    },
    {
      "start": 157.06,
      "end": 159.06,
      "text": "我的生活他的梦"
    },
    {
      "start": 159.06,
      "end": 162.06,
      "text": "我能作为他一个"
    },
    {
      "start": 162.06,
      "end": 164.06,
      "text": "全血泄氛的一个"
    },
    {
      "start": 164.06,
      "end": 166.06,
      "text": "感弯"
    },
    {
      "start": 166.06,
      "end": 168.06,
      "text": "就像对面大弯去"
    },
    {
      "start": 169.06,
      "end": 170.06,
      "text": "我觉得"
    },
    {
      "start": 170.06,
      "end": 174.06,
      "text": "我也是在这一套"
    }
  ]
}