{
  "aweme_id": "7555142563020901691",
  "language": "zh",
  "duration": 168.0906875,
  "segments": [
    {
      "start": 0.0,
      "end": 2.04,
      "text": "预测于知这方面的"
    },
    {
      "start": 2.04,
      "end": 4.6,
      "text": "一直没有比较再去战结成的"
    },
    {
      "start": 4.6,
      "end": 6.4,
      "text": "一失利了"
    },
    {
      "start": 6.4,
      "end": 8.96,
      "text": "但让我还是那句话"
    },
    {
      "start": 8.96,
      "end": 11.28,
      "text": "没有说版本版的这句话"
    },
    {
      "start": 11.28,
      "end": 12.8,
      "text": "人种那么多"
    },
    {
      "start": 12.8,
      "end": 15.12,
      "text": "但未来我还是会继续保持"
    },
    {
      "start": 15.12,
      "end": 16.2,
      "text": "看到的话"
    },
    {
      "start": 16.2,
      "end": 18.96,
      "text": "尽量都还会给你们说"
    },
    {
      "start": 18.96,
      "end": 22.4,
      "text": "尽量还是会把预测是请都说出来"
    },
    {
      "start": 22.4,
      "end": 26.36,
      "text": "但未来的话可能明年"
    },
    {
      "start": 26.36,
      "end": 29.32,
      "text": "就不一定会有那么高的这句话"
    },
    {
      "start": 29.32,
      "end": 32.32,
      "text": "没有使你人保证多元的百分百分"
    },
    {
      "start": 32.32,
      "end": 38.32,
      "text": "尽量也所有的心情"
    },
    {
      "start": 38.32,
      "end": 39.32,
      "text": "那个时候"
    },
    {
      "start": 39.32,
      "end": 41.32,
      "text": "我说行行"
    },
    {
      "start": 41.32,
      "end": 48.35,
      "text": "还有一堆人在下面骂我"
    },
    {
      "start": 48.35,
      "end": 50.35,
      "text": "还有甚至有的"
    },
    {
      "start": 50.35,
      "end": 51.35,
      "text": "尽量很搞笑"
    },
    {
      "start": 51.35,
      "end": 52.35,
      "text": "私信来说"
    },
    {
      "start": 52.35,
      "end": 56.35,
      "text": "各为作为行行的工作人员"
    },
    {
      "start": 56.35,
      "end": 58.35,
      "text": "当时对你那条视频"
    },
    {
      "start": 58.35,
      "end": 62.94,
      "text": "一一"
    },
    {
      "start": 62.94,
      "end": 64.94,
      "text": "但是现在她说"
    },
    {
      "start": 64.94,
      "end": 66.94,
      "text": "你说的对你"
    },
    {
      "start": 66.94,
      "end": 68.94,
      "text": "其实还是一句话"
    },
    {
      "start": 68.94,
      "end": 73.51,
      "text": "你们大部分人还是没有人一起"
    },
    {
      "start": 73.51,
      "end": 75.51,
      "text": "就拿这个私信的说"
    },
    {
      "start": 75.51,
      "end": 77.51,
      "text": "她说好像好像工作人员"
    },
    {
      "start": 77.51,
      "end": 80.51,
      "text": "你怎么定义工作人员"
    },
    {
      "start": 80.51,
      "end": 81.51,
      "text": "那在行行"
    },
    {
      "start": 81.51,
      "end": 83.51,
      "text": "但保安"
    },
    {
      "start": 83.51,
      "end": 89.1,
      "text": "那个保安是不是好像工作人员"
    },
    {
      "start": 89.1,
      "end": 90.1,
      "text": "你是给"
    },
    {
      "start": 90.1,
      "end": 92.1,
      "text": "她也大妈"
    },
    {
      "start": 92.1,
      "end": 96.53,
      "text": "但一人我的三部不理所"
    },
    {
      "start": 96.53,
      "end": 97.53,
      "text": "人在那个小贵台"
    },
    {
      "start": 97.53,
      "end": 99.53,
      "text": "你就觉得自己"
    },
    {
      "start": 99.53,
      "end": 101.53,
      "text": "等行行的里面所有的东西"
    },
    {
      "start": 101.53,
      "end": 104.03,
      "text": "不是"
    },
    {
      "start": 104.03,
      "end": 110.6,
      "text": "你是给你们传达的"
    },
    {
      "start": 110.6,
      "end": 113.6,
      "text": "你说地某程已经搞了"
    },
    {
      "start": 113.6,
      "end": 119.03,
      "text": "现在近期的信号呢"
    },
    {
      "start": 119.03,
      "end": 121.03,
      "text": "并且我"
    },
    {
      "start": 121.03,
      "end": 122.03,
      "text": "只不过说一直在给你们说的"
    },
    {
      "start": 122.03,
      "end": 123.03,
      "text": "是什么"
    },
    {
      "start": 123.03,
      "end": 125.03,
      "text": "还没这样到底呢"
    },
    {
      "start": 125.03,
      "end": 127.03,
      "text": "只是在这儿"
    },
    {
      "start": 127.03,
      "end": 128.03,
      "text": "只是在这儿近期"
    },
    {
      "start": 128.03,
      "end": 130.03,
      "text": "发生了些傻"
    },
    {
      "start": 130.03,
      "end": 132.03,
      "text": "不是你"
    },
    {
      "start": 132.03,
      "end": 133.03,
      "text": "还有人说"
    },
    {
      "start": 133.03,
      "end": 134.03,
      "text": "哥现在"
    },
    {
      "start": 134.03,
      "end": 135.03,
      "text": "是不是这个"
    },
    {
      "start": 135.03,
      "end": 137.03,
      "text": "万猛"
    },
    {
      "start": 137.03,
      "end": 139.03,
      "text": "打这个出这个事了"
    },
    {
      "start": 139.03,
      "end": 140.03,
      "text": "以后"
    },
    {
      "start": 140.03,
      "end": 141.03,
      "text": "是不是意味着可以朝底"
    },
    {
      "start": 141.03,
      "end": 142.03,
      "text": "又毛病"
    },
    {
      "start": 143.03,
      "end": 144.03,
      "text": "老子呢"
    },
    {
      "start": 144.03,
      "end": 146.03,
      "text": "把我的话当放屁"
    },
    {
      "start": 146.03,
      "end": 148.03,
      "text": "我说的是没到地"
    },
    {
      "start": 148.03,
      "end": 149.03,
      "text": "没到点"
    },
    {
      "start": 149.03,
      "end": 151.03,
      "text": "只是在这儿半山"
    },
    {
      "start": 151.03,
      "end": 153.03,
      "text": "要"
    },
    {
      "start": 153.03,
      "end": 157.4,
      "text": "要的还没妖展"
    },
    {
      "start": 157.4,
      "end": 158.4,
      "text": "那"
    },
    {
      "start": 158.4,
      "end": 159.4,
      "text": "竟然回来了"
    },
    {
      "start": 159.4,
      "end": 160.4,
      "text": "没有"
    }
  ]
}