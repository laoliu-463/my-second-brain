{
  "aweme_id": "7532750123852877115",
  "language": "zh",
  "duration": 98.8705625,
  "segments": [
    {
      "start": 0.0,
      "end": 3.44,
      "text": "強大無需多元了吧"
    },
    {
      "start": 3.44,
      "end": 5.14,
      "text": "就對於興奮而言"
    },
    {
      "start": 5.14,
      "end": 7.04,
      "text": "看不懂很多東西很正常"
    },
    {
      "start": 7.04,
      "end": 8.94,
      "text": "因為我前面已經說過了"
    },
    {
      "start": 8.94,
      "end": 10.44,
      "text": "我的內容"
    },
    {
      "start": 10.44,
      "end": 14.44,
      "text": "基本現在都是在給老闆在看"
    },
    {
      "start": 14.44,
      "end": 16.24,
      "text": "那沒有看過的"
    },
    {
      "start": 16.24,
      "end": 17.44,
      "text": "不知道預測是在說"
    },
    {
      "start": 17.44,
      "end": 18.94,
      "text": "我胡說八道的"
    },
    {
      "start": 18.94,
      "end": 20.44,
      "text": "你去看以前的視頻"
    },
    {
      "start": 20.44,
      "end": 22.44,
      "text": "看完以後再說"
    },
    {
      "start": 22.44,
      "end": 23.84,
      "text": "那或者說是你看完以後"
    },
    {
      "start": 23.84,
      "end": 24.94,
      "text": "還覺得我身館的"
    },
    {
      "start": 24.94,
      "end": 26.74,
      "text": "那我就覺得我身館"
    },
    {
      "start": 26.74,
      "end": 29.24,
      "text": "反正該應都應了"
    },
    {
      "start": 29.24,
      "end": 30.94,
      "text": "接下來"
    },
    {
      "start": 30.94,
      "end": 33.94,
      "text": "各位就只剩4元了"
    },
    {
      "start": 33.94,
      "end": 35.94,
      "text": "你4元的話"
    },
    {
      "start": 35.94,
      "end": 38.94,
      "text": "關閉一下今天下午"
    },
    {
      "start": 38.94,
      "end": 39.94,
      "text": "關閉下今天下午"
    },
    {
      "start": 39.94,
      "end": 40.94,
      "text": "一年"
    },
    {
      "start": 40.94,
      "end": 42.94,
      "text": "的預測從去年年底"
    },
    {
      "start": 42.94,
      "end": 44.94,
      "text": "到年初基本都做完了"
    },
    {
      "start": 44.94,
      "end": 46.94,
      "text": "只是後面一直在等時間"
    },
    {
      "start": 46.94,
      "end": 48.94,
      "text": "一年而已"
    },
    {
      "start": 48.94,
      "end": 50.94,
      "text": "那後面就給你們"
    },
    {
      "start": 50.94,
      "end": 51.94,
      "text": "更新一年"
    },
    {
      "start": 51.94,
      "end": 52.94,
      "text": "是他的內容"
    },
    {
      "start": 52.94,
      "end": 53.94,
      "text": "回歸到以前吧"
    },
    {
      "start": 53.94,
      "end": 54.94,
      "text": "不要了"
    },
    {
      "start": 54.94,
      "end": 56.94,
      "text": "上夜要了要認知"
    },
    {
      "start": 56.94,
      "end": 58.94,
      "text": "要要投資"
    },
    {
      "start": 58.94,
      "end": 62.57,
      "text": "有預測的話在說"
    },
    {
      "start": 62.57,
      "end": 63.57,
      "text": "在看"
    },
    {
      "start": 63.57,
      "end": 64.57,
      "text": "沒有想過"
    },
    {
      "start": 64.57,
      "end": 65.57,
      "text": "有多少分子的死"
    },
    {
      "start": 65.57,
      "end": 67.57,
      "text": "因為我不管是"
    },
    {
      "start": 67.57,
      "end": 68.57,
      "text": "給你們看吧"
    },
    {
      "start": 68.57,
      "end": 69.57,
      "text": "也好"
    },
    {
      "start": 69.57,
      "end": 71.57,
      "text": "一個人的經歷詢獻"
    },
    {
      "start": 71.57,
      "end": 73.57,
      "text": "這樣服務的人"
    },
    {
      "start": 73.57,
      "end": 75.57,
      "text": "中秋就是那麼多"
    },
    {
      "start": 75.57,
      "end": 77.57,
      "text": "不然我媽不過"
    },
    {
      "start": 77.57,
      "end": 79.57,
      "text": "我本質的身"
    },
    {
      "start": 79.57,
      "end": 80.57,
      "text": "那些生意性"
    },
    {
      "start": 80.57,
      "end": 81.57,
      "text": "那些投資"
    },
    {
      "start": 81.57,
      "end": 82.57,
      "text": "平臺"
    },
    {
      "start": 82.57,
      "end": 83.57,
      "text": "我不管了"
    },
    {
      "start": 83.57,
      "end": 85.57,
      "text": "那些才是最主要"
    }
  ]
}