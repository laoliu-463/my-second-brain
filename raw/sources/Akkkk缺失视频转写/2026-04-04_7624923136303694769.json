{
  "aweme_id": "7624923136303694769",
  "language": "zh",
  "duration": 172.8958125,
  "segments": [
    {
      "start": 0.0,
      "end": 3.96,
      "text": "这不清明那么直播的时候好多人的那里问"
    },
    {
      "start": 3.96,
      "end": 6.96,
      "text": "什么什么是不是不醒醒什么是不是不醒"
    },
    {
      "start": 6.96,
      "end": 8.76,
      "text": "那不醒这不醒"
    },
    {
      "start": 8.76,
      "end": 11.56,
      "text": "然后今天刷个小脱脱音"
    },
    {
      "start": 11.56,
      "end": 12.96,
      "text": "也看到了那些但是"
    },
    {
      "start": 12.96,
      "end": 14.44,
      "text": "但是说这不醒那不醒"
    },
    {
      "start": 14.44,
      "end": 20.14,
      "text": "这出门那出门"
    },
    {
      "start": 20.14,
      "end": 21.9,
      "text": "不去就不去吗"
    },
    {
      "start": 21.9,
      "end": 22.9,
      "text": "这符吾了"
    },
    {
      "start": 22.9,
      "end": 24.5,
      "text": "这些所谓的规矩啊"
    },
    {
      "start": 24.5,
      "end": 25.7,
      "text": "没有办法去"
    },
    {
      "start": 25.7,
      "end": 27.5,
      "text": "正式没有办法去正为"
    },
    {
      "start": 27.5,
      "end": 28.9,
      "text": "是吧"
    },
    {
      "start": 30.18,
      "end": 30.9,
      "text": "人呢"
    },
    {
      "start": 30.9,
      "end": 33.26,
      "text": "是不能用自己的比较"
    },
    {
      "start": 33.26,
      "end": 34.5,
      "text": "规矩"
    },
    {
      "start": 34.5,
      "end": 36.78,
      "text": "来头设到那边去的"
    },
    {
      "start": 36.78,
      "end": 38.7,
      "text": "你应该说有用"
    },
    {
      "start": 38.7,
      "end": 40.3,
      "text": "我没用这个才面的话"
    },
    {
      "start": 40.3,
      "end": 41.38,
      "text": "那不得儿子"
    },
    {
      "start": 41.38,
      "end": 42.42,
      "text": "除非你搞了"
    },
    {
      "start": 42.42,
      "end": 43.58,
      "text": "或者说我搞了"
    },
    {
      "start": 43.58,
      "end": 45.18,
      "text": "去到那里才知道"
    },
    {
      "start": 45.18,
      "end": 46.86,
      "text": "是是"
    },
    {
      "start": 46.86,
      "end": 49.1,
      "text": "最重要的输了无输资"
    },
    {
      "start": 49.1,
      "end": 50.26,
      "text": "新了"
    },
    {
      "start": 50.26,
      "end": 51.7,
      "text": "什么时候接所谓的"
    },
    {
      "start": 51.7,
      "end": 52.7,
      "text": "有的没有的规矩"
    },
    {
      "start": 52.7,
      "end": 54.7,
      "text": "或者说是有的没有的"
    },
    {
      "start": 54.7,
      "end": 55.9,
      "text": "我排着脑袋就来的"
    },
    {
      "start": 55.9,
      "end": 56.86,
      "text": "这些人说白了就是"
    },
    {
      "start": 56.86,
      "end": 58.54,
      "text": "排着脑袋乱说"
    },
    {
      "start": 58.54,
      "end": 61.74,
      "text": "以前脑袋有这么多网页冒出来"
    },
    {
      "start": 61.74,
      "end": 63.18,
      "text": "新义最重要"
    },
    {
      "start": 63.18,
      "end": 64.94,
      "text": "什么时候这个新义"
    },
    {
      "start": 64.94,
      "end": 66.54,
      "text": "都不重要了"
    },
    {
      "start": 66.54,
      "end": 68.86,
      "text": "就被接东西给"
    },
    {
      "start": 68.86,
      "end": 73.45,
      "text": "带过了或者说是默平"
    },
    {
      "start": 73.45,
      "end": 74.81,
      "text": "真的是没得什么输的了"
    },
    {
      "start": 74.81,
      "end": 75.69,
      "text": "我反应接"
    },
    {
      "start": 75.69,
      "end": 76.97,
      "text": "那多说一点"
    },
    {
      "start": 76.97,
      "end": 79.61,
      "text": "寄平"
    },
    {
      "start": 79.61,
      "end": 82.33,
      "text": "那最高级的寄平是啥"
    },
    {
      "start": 82.33,
      "end": 83.29,
      "text": "人吗"
    },
    {
      "start": 83.29,
      "end": 84.81,
      "text": "那是不是寸寄"
    },
    {
      "start": 84.81,
      "end": 87.85,
      "text": "确实以前就这么改的吗"
    },
    {
      "start": 87.85,
      "end": 90.09,
      "text": "但是现在所有"
    },
    {
      "start": 90.09,
      "end": 91.45,
      "text": "什么一切的寄平"
    },
    {
      "start": 91.45,
      "end": 93.77,
      "text": "都不如你的新义吗"
    },
    {
      "start": 93.77,
      "end": 95.37,
      "text": "就所谓的法控表"
    },
    {
      "start": 95.37,
      "end": 98.49,
      "text": "这个是否掉进来以后的概念"
    },
    {
      "start": 98.49,
      "end": 99.85,
      "text": "就是你的这个念头"
    },
    {
      "start": 99.85,
      "end": 100.57,
      "text": "我的这个念头"
    },
    {
      "start": 100.57,
      "end": 102.01,
      "text": "我对你的"
    },
    {
      "start": 102.01,
      "end": 102.89,
      "text": "尽管新"
    },
    {
      "start": 102.89,
      "end": 103.69,
      "text": "尊敬新"
    },
    {
      "start": 103.69,
      "end": 104.81,
      "text": "尊敬新"
    },
    {
      "start": 104.81,
      "end": 107.05,
      "text": "亲敬新等等"
    },
    {
      "start": 107.05,
      "end": 109.77,
      "text": "最高级的共谣"
    },
    {
      "start": 109.77,
      "end": 111.61,
      "text": "高果所有的物质"
    },
    {
      "start": 111.61,
      "end": 112.73,
      "text": "比你杀个猪"
    },
    {
      "start": 112.73,
      "end": 113.37,
      "text": "杀个低级"
    },
    {
      "start": 113.37,
      "end": 115.69,
      "text": "分之杀车轮放在哪里"
    },
    {
      "start": 115.69,
      "end": 116.73,
      "text": "都要有"
    },
    {
      "start": 116.73,
      "end": 118.49,
      "text": "你杀这些还造个杀业"
    },
    {
      "start": 118.49,
      "end": 119.21,
      "text": "那好多人"
    },
    {
      "start": 119.21,
      "end": 120.49,
      "text": "买了这些年轻人"
    },
    {
      "start": 120.49,
      "end": 121.69,
      "text": "现在最流行的"
    },
    {
      "start": 121.69,
      "end": 123.21,
      "text": "对部毛圈的相求"
    },
    {
      "start": 123.21,
      "end": 125.53,
      "text": "这个意义的事"
    },
    {
      "start": 125.53,
      "end": 126.65,
      "text": "但重点"
    },
    {
      "start": 126.65,
      "end": 127.29,
      "text": "你们很短线"
    },
    {
      "start": 127.29,
      "end": 128.81,
      "text": "在朋友喜欢白之后"
    },
    {
      "start": 128.81,
      "end": 131.61,
      "text": "求这高级的东西"
    },
    {
      "start": 131.61,
      "end": 133.61,
      "text": "你没有我们都摆错"
    },
    {
      "start": 133.61,
      "end": 135.13,
      "text": "普撒是不管你这些的"
    },
    {
      "start": 135.13,
      "end": 137.37,
      "text": "普撒虽然说就苦就嫩"
    },
    {
      "start": 137.37,
      "end": 138.89,
      "text": "但是你去"
    },
    {
      "start": 138.89,
      "end": 139.93,
      "text": "用这些去求的那个"
    },
    {
      "start": 139.93,
      "end": 141.61,
      "text": "是他未必会扭你"
    },
    {
      "start": 141.61,
      "end": 142.73,
      "text": "明白吧"
    },
    {
      "start": 142.73,
      "end": 145.53,
      "text": "你们你不如去摆什么扭扭"
    },
    {
      "start": 145.53,
      "end": 146.73,
      "text": "我后说是什么龙王"
    },
    {
      "start": 146.73,
      "end": 148.41,
      "text": "或者说是什么徒徒什么第一样的"
    },
    {
      "start": 148.41,
      "end": 150.41,
      "text": "甚至被说服务间积决"
    },
    {
      "start": 150.41,
      "end": 151.93,
      "text": "然后直播说"
    },
    {
      "start": 151.93,
      "end": 152.33,
      "text": "也给你们说了"
    },
    {
      "start": 152.33,
      "end": 152.81,
      "text": "朝上第一句"
    },
    {
      "start": 152.81,
      "end": 154.49,
      "text": "今天你那个资堂"
    },
    {
      "start": 154.49,
      "end": 155.29,
      "text": "你去败钱"
    },
    {
      "start": 155.29,
      "end": 156.97,
      "text": "都要比你去与资妙"
    },
    {
      "start": 156.97,
      "end": 158.17,
      "text": "你去求"
    },
    {
      "start": 158.17,
      "end": 160.17,
      "text": "那要有点有用的多"
    },
    {
      "start": 160.17,
      "end": 161.77,
      "text": "你要门都摆错"
    },
    {
      "start": 161.77,
      "end": 163.69,
      "text": "这几周你没有分清楚的是"
    },
    {
      "start": 163.69,
      "end": 164.65,
      "text": "什么是四"
    },
    {
      "start": 164.65,
      "end": 166.09,
      "text": "什么是妙"
    },
    {
      "start": 166.09,
      "end": 168.09,
      "text": "那刚才给你们说的那个资堂"
    },
    {
      "start": 168.09,
      "end": 170.09,
      "text": "那是妙"
    },
    {
      "start": 170.09,
      "end": 172.49,
      "text": "你要搞清楚这两个的区别"
    }
  ]
}