  "segments": [
    {
      "start": 0.0,
      "end": 2.32,
      "text": "建于一些年纪特别小的"
    },
    {
      "start": 2.32,
      "end": 4.94,
      "text": "还有一些认知欠缺的"
    },
    {
      "start": 4.94,
      "end": 7.8,
      "text": "包括这个社会月里的各方面呢"
    },
    {
      "start": 7.8,
      "end": 9.48,
      "text": "都很欠缺的分子"
    },
    {
      "start": 10.24,
      "end": 12.04,
      "text": "我要给你们说明一下"
    },
    {
      "start": 12.28,
      "end": 14.72,
      "text": "不论是那些老鼠"
    },
    {
      "start": 14.72,
      "end": 18.44,
      "text": "他要拿我的信息也好"
    },
    {
      "start": 18.44,
      "end": 21.76,
      "text": "我说是直播的路平也好"
    },
    {
      "start": 21.76,
      "end": 24.32,
      "text": "是从的路平也好各种"
    },
    {
      "start": 25.04,
      "end": 29.68,
      "text": "建权或者是发表给别人"
    },
    {
      "start": 29.68,
      "end": 31.76,
      "text": "造成了一些厉害的问题"
    },
    {
      "start": 32.12,
      "end": 34.28,
      "text": "那如果关好"
    },
    {
      "start": 34.28,
      "end": 35.92,
      "text": "如果如果关"
    },
    {
      "start": 35.92,
      "end": 37.64,
      "text": "我也不会去再议他们"
    },
    {
      "start": 37.64,
      "end": 39.6,
      "text": "我给你们说的是我不会去再议"
    },
    {
      "start": 39.6,
      "end": 41.48,
      "text": "但是有一个点"
    },
    {
      "start": 41.48,
      "end": 43.36,
      "text": "也明确的跟你们"
    },
    {
      "start": 43.36,
      "end": 45.08,
      "text": "中一个毛"
    },
    {
      "start": 45.08,
      "end": 47.48,
      "text": "商人生意人的话"
    },
    {
      "start": 47.48,
      "end": 49.08,
      "text": "你只能听一半"
    },
    {
      "start": 49.08,
      "end": 51.28,
      "text": "你只能信一半"
    },
    {
      "start": 51.28,
      "end": 53.68,
      "text": "一来跟我说谁谁"
    },
    {
      "start": 53.68,
      "end": 54.96,
      "text": "搞的权忆"
    },
    {
      "start": 54.96,
      "end": 57.08,
      "text": "发了我这个路平要什么"
    },
    {
      "start": 57.08,
      "end": 58.52,
      "text": "就没有想过"
    },
    {
      "start": 58.52,
      "end": 60.44,
      "text": "如果作为一个生态位"
    },
    {
      "start": 60.44,
      "end": 62.4,
      "text": "比这些人要高的人"
    },
    {
      "start": 62.4,
      "end": 64.16,
      "text": "会怎么去逃作呢"
    },
    {
      "start": 64.16,
      "end": 65.52,
      "text": "首先"
    },
    {
      "start": 65.52,
      "end": 68.44,
      "text": "把你们这些来跟我说的人"
    },
    {
      "start": 68.44,
      "end": 72.2,
      "text": "我会让你去加他进权"
    },
    {
      "start": 72.2,
      "end": 73.96,
      "text": "然后花钱"
    },
    {
      "start": 73.96,
      "end": 75.56,
      "text": "花万钱以后"
    },
    {
      "start": 75.56,
      "end": 78.12,
      "text": "把这些聊天记录"
    },
    {
      "start": 79.08,
      "end": 83.08,
      "text": "图片各种保留好以后"
    },
    {
      "start": 83.08,
      "end": 84.12,
      "text": "给到我"
    },
    {
      "start": 84.12,
      "end": 85.56,
      "text": "却我说了很多次"
    },
    {
      "start": 85.56,
      "end": 88.52,
      "text": "我没有任何的直播路平"
    },
    {
      "start": 88.52,
      "end": 91.84,
      "text": "我也没有设任何的群"
    },
    {
      "start": 91.84,
      "end": 94.52,
      "text": "这个时候你们"
    },
    {
      "start": 94.52,
      "end": 96.2,
      "text": "给到我这些证据练"
    },
    {
      "start": 96.2,
      "end": 98.6,
      "text": "给到我这些记录的时候"
    },
    {
      "start": 98.6,
      "end": 100.08,
      "text": "可以"
    },
    {
      "start": 100.08,
      "end": 100.76,
      "text": "干嘛"
    },
    {
      "start": 100.76,
      "end": 104.0,
      "text": "我可以请他生男生必须可以吗"
    },
    {
      "start": 104.0,
      "end": 106.28,
      "text": "用人点心的就是"
    },
    {
      "start": 106.32,
      "end": 108.52,
      "text": "没脑子没认知"
    },
    {
      "start": 108.52,
      "end": 110.48,
      "text": "他觉得他是一个"
    },
    {
      "start": 110.48,
      "end": 111.76,
      "text": "下位这"
    },
    {
      "start": 111.76,
      "end": 113.6,
      "text": "不欺验的人"
    },
    {
      "start": 113.6,
      "end": 115.2,
      "text": "信息不可以被查到什么"
    },
    {
      "start": 115.2,
      "end": 117.6,
      "text": "这是很搞笑的"
    },
    {
      "start": 117.6,
      "end": 120.6,
      "text": "我们对强大的就是信息"
    },
    {
      "start": 120.6,
      "end": 121.8,
      "text": "对吧"
    },
    {
      "start": 121.8,
      "end": 122.6,
      "text": "说过很多次了"
    },
    {
      "start": 122.6,
      "end": 125.2,
      "text": "我们非常强大的是信息"
    },
    {
      "start": 125.2,
      "end": 126.68,
      "text": "哎"
    },
    {
      "start": 126.68,
      "end": 129.08,
      "text": "我觉得自己能到时候能躲啊"
    },
    {
      "start": 129.08,
      "end": 131.24,
      "text": "不好意思"
    },
    {
      "start": 131.24,
      "end": 132.44,
      "text": "这个时候不能法的话"
    },
    {
      "start": 132.44,
      "end": 133.88,
      "text": "我给你可不以下"
    },
    {
      "start": 133.88,
      "end": 135.72,
      "text": "用我的路平用我的脸"
    },
    {
      "start": 135.72,
      "end": 138.08,
      "text": "用我的信息"
    },
    {
      "start": 138.08,
      "end": 139.12,
      "text": "哦"
    },
    {
      "start": 139.12,
      "end": 142.08,
      "text": "他都不知道他犯了什么事"
    },
    {
      "start": 142.08,
      "end": 144.24,
      "text": "行发里面有个差片"
    },
    {
      "start": 144.24,
      "end": 146.24,
      "text": "266条差片罪"
    },
    {
      "start": 146.24,
      "end": 147.88,
      "text": "还有名发点里面的"
    },
    {
      "start": 147.88,
      "end": 150.56,
      "text": "1千"
    },
    {
      "start": 150.56,
      "end": 151.72,
      "text": "1千1条"
    },
    {
      "start": 151.72,
      "end": 153.88,
      "text": "对还1千1条"
    },
    {
      "start": 153.88,
      "end": 158.36,
      "text": "1千就已经跟我的律师聊过了"
    },
    {
      "start": 158.36,
      "end": 161.04,
      "text": "认知就不在一个层面"
    },
    {
      "start": 161.04,
      "end": 162.12,
      "text": "明一权"
    },
    {
      "start": 162.12,
      "end": 164.08,
      "text": "小像权"
    },
    {
      "start": 164.08,
      "end": 166.68,
      "text": "到时候所有解释权都在于我"
    },
    {
      "start": 166.68,
      "end": 168.12,
      "text": "至于这种人可能会说"
    },
    {
      "start": 168.12,
      "end": 170.32,
      "text": "那我视频内容以及直播内容"
    },
    {
      "start": 170.32,
      "end": 172.72,
      "text": "传达的都是那些"
    },
    {
      "start": 172.72,
      "end": 174.72,
      "text": "我还是那句话"
    },
    {
      "start": 174.72,
      "end": 176.32,
      "text": "在一个生态为比你高"
    },
    {
      "start": 176.32,
      "end": 179.0,
      "text": "并且现实层面严"
    },
    {
      "start": 179.0,
      "end": 180.68,
      "text": "有很多牵扯的"
    },
    {
      "start": 180.68,
      "end": 181.84,
      "text": "圈子"
    },
    {
      "start": 181.84,
      "end": 184.52,
      "text": "你不足为御"
    },
    {
      "start": 184.52,
      "end": 185.96,
      "text": "并且不足为御"
    },
    {
      "start": 185.96,
      "end": 187.92,
      "text": "你放错我在先"
    },
    {
      "start": 187.92,
      "end": 190.16,
      "text": "直播内容以及视频内容解释权"
    },
    {
      "start": 190.16,
      "end": 192.36,
      "text": "但是在我这里"
    },
    {
      "start": 192.36,
      "end": 195.36,
      "text": "而你方法了"
    },
    {
      "start": 195.36,
      "end": 197.04,
      "text": "不是说不管"
    },
    {
      "start": 197.04,
      "end": 199.96,
      "text": "是现在我觉得终不够随"
    },
    {
      "start": 199.96,
      "end": 201.16,
      "text": "在养异啊"
    },
    {
      "start": 201.16,
      "end": 203.12,
      "text": "并且总有人喜欢"
    },
    {
      "start": 203.12,
      "end": 206.24,
      "text": "养谷骂 养谷骂"
    },
    {
      "start": 206.24,
      "end": 207.68,
      "text": "明白吗"
    },
    {
      "start": 207.68,
      "end": 209.8,
      "text": "就像我现在公开去说这个事情"
    },
    {
      "start": 209.8,
      "end": 211.52,
      "text": "他还是会去做这个事情"
    },
    {
      "start": 211.52,
      "end": 214.24,
      "text": "这就是命难看"
    },
    {
      "start": 214.24,
      "end": 217.28,
      "text": "那比人不才"
    },
    {
      "start": 217.28,
      "end": 218.88,
      "text": "这个審思没多少"
    },
    {
      "start": 218.88,
      "end": 220.48,
      "text": "但是我觉得"
    },
    {
      "start": 220.48,
      "end": 222.28,
      "text": "但反而"
    },
    {
      "start": 222.28,
      "end": 224.32,
      "text": "让你们去得到这个记录啊"
    },
    {
      "start": 224.32,
      "end": 225.08,
      "text": "各种的"
    },
    {
      "start": 225.08,
      "end": 226.08,
      "text": "找到我"
    },
    {
      "start": 226.08,
      "end": 226.88,
      "text": "给到我"
    },
    {
      "start": 226.88,
      "end": 227.68,
      "text": "聊天记录"
    },
    {
      "start": 227.68,
      "end": 230.28,
      "text": "和信息以后"
    },
    {
      "start": 230.28,
      "end": 232.48,
      "text": "杀猪范全吞人士"
    },
    {
      "start": 232.48,
      "end": 233.48,
      "text": "是不是"
    },
    {
      "start": 233.48,
      "end": 235.08,
      "text": "他所配唱给我的"
    },
    {
      "start": 235.08,
      "end": 235.88,
      "text": "我说"
    },
    {
      "start": 235.88,
      "end": 236.8,
      "text": "请他吃南山"
    },
    {
      "start": 236.8,
      "end": 239.08,
      "text": "必须客的那些金额"
    },
    {
      "start": 239.08,
      "end": 240.08,
      "text": "有"
    },
    {
      "start": 240.08,
      "end": 241.68,
      "text": "我这边拿到以后"
    },
    {
      "start": 241.68,
      "end": 243.76,
      "text": "再给到你们的提供"
    },
    {
      "start": 243.76,
      "end": 246.08,
      "text": "证据的提供信息的人"
    },
    {
      "start": 246.08,
      "end": 247.88,
      "text": "一起吃杀猪范"
    },
    {
      "start": 248.88,
      "end": 250.88,
      "text": "你们现在老焦啥叫啊"
    },
    {
      "start": 251.88,
      "end": 252.88,
      "text": "是不是"
    },
    {
      "start": 252.88,
      "end": 253.88,
      "text": "在等一等"
    },
    {
      "start": 253.88,
      "end": 255.88,
      "text": "总会有这种人出现的"
    },
    {
      "start": 255.88,
      "end": 256.88,
      "text": "要一样"
    },
    {
      "start": 257.88,
      "end": 259.88,
      "text": "杀猪范全吞人士"
    },
    {
      "start": 259.88,
      "end": 260.88,
      "text": "才是像的"
    },
    {
      "start": 260.88,
      "end": 261.88,
      "text": "现实利益层面"
    },
    {
      "start": 261.88,
      "end": 262.88,
      "text": "如果因为这些什么"
    },
    {
      "start": 262.88,
      "end": 264.88,
      "text": "导致我的一些经济存识"
    },
    {
      "start": 264.88,
      "end": 266.88,
      "text": "合作丢失"
    },
    {
      "start": 266.88,
      "end": 267.88,
      "text": "理戏列"
    },
    {
      "start": 269.88,
      "end": 270.88,
      "text": "我可以"
    },
    {
      "start": 270.88,
      "end": 273.83,
      "text": "对吧"
    },
    {
      "start": 273.83,
      "end": 275.83,
      "text": "都是解释全在我"
    },
    {
      "start": 275.83,
      "end": 276.83,
      "text": "就算没有丢"
    },
    {
      "start": 276.83,
      "end": 277.83,
      "text": "我也说丢了"
    },
    {
      "start": 278.83,
      "end": 280.83,
      "text": "我也能提供证据"
    },
    {
      "start": 280.83,
      "end": 281.83,
      "text": "他没有体验过"
    },
    {
      "start": 281.83,
      "end": 282.83,
      "text": "社会心死亡"
    },
    {
      "start": 282.83,
      "end": 283.83,
      "text": "就让他体验"
    },
    {
      "start": 283.83,
      "end": 284.83,
      "text": "讲真正的"
    },
    {
      "start": 284.83,
      "end": 285.83,
      "text": "社会心死亡"
    },
    {
      "start": 285.83,
      "end": 286.83,
      "text": "那这个时候"
    },
    {
      "start": 286.83,
      "end": 288.83,
      "text": "大家一起吃杀猪范"
    },
    {
      "start": 288.83,
      "end": 290.83,
      "text": "普天同情"
    },
    {
      "start": 290.83,
      "end": 292.83,
      "text": "然后你在居到他"
    },
    {
      "start": 292.83,
      "end": 293.83,
      "text": "都配款"
    },
    {
      "start": 293.83,
      "end": 294.83,
      "text": "他不仅好像我配钱"
    },
    {
      "start": 294.83,
      "end": 296.83,
      "text": "还要陪你闷钱"
    },
    {
      "start": 296.83,
      "end": 297.83,
      "text": "那"
    },
    {
      "start": 297.83,
      "end": 299.83,
      "text": "一百个人他能承担"
    },
    {
      "start": 299.83,
      "end": 300.83,
      "text": "一千个人呢"
    },
    {
      "start": 300.83,
      "end": 301.83,
      "text": "两千个人呢"
    },
    {
      "start": 301.83,
      "end": 302.83,
      "text": "把我"
    },
    {
      "start": 302.83,
      "end": 304.83,
      "text": "养费一点"
    },
    {
      "start": 305.83,
      "end": 306.83,
      "text": "这条视频就保留一小意"
    },
    {
      "start": 306.83,
      "end": 308.83,
      "text": "一段时间"
    }
  ]
