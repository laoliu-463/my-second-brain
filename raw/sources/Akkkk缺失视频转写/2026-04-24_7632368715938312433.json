      "start": 632.09,
      "end": 633.09,
      "text": "別看了"
    },
    {
      "start": 633.09,
      "end": 635.09,
      "text": "你水平不行"
    },
    {
      "start": 635.09,
      "end": 637.09,
      "text": "四五位"
    },
    {
      "start": 637.09,
      "end": 638.09,
      "text": "三位"
    },
    {
      "start": 638.09,
      "end": 639.09,
      "text": "南方火"
    },
    {
      "start": 639.09,
      "end": 640.09,
      "text": "什麼火"
    },
    {
      "start": 640.09,
      "end": 641.09,
      "text": "南方的什麼火"
    },
    {
      "start": 641.09,
      "end": 644.59,
      "text": "會的是什麼火"
    },
    {
      "start": 644.59,
      "end": 646.59,
      "text": "任何基礎上都說了"
    },
    {
      "start": 646.59,
      "end": 648.59,
      "text": "火分音火"
    },
    {
      "start": 648.59,
      "end": 649.59,
      "text": "洋火"
    },
    {
      "start": 649.59,
      "end": 651.59,
      "text": "那洋火還是音火"
    },
    {
      "start": 651.59,
      "end": 652.59,
      "text": "還是什麼火"
    },
    {
      "start": 652.59,
      "end": 653.59,
      "text": "告訴我"
    },
    {
      "start": 653.59,
      "end": 654.59,
      "text": "嗯"
    },
    {
      "start": 654.59,
      "end": 655.59,
      "text": "轉確地告訴我"
    },
    {
      "start": 655.59,
      "end": 656.59,
      "text": "什麼火"
    },
    {
      "start": 656.59,
      "end": 657.59,
      "text": "有人說"
    },
    {
      "start": 657.59,
      "end": 658.59,
      "text": "反正都是火"
    },
    {
      "start": 658.59,
      "end": 659.59,
      "text": "那這個就沒得了"
    },
    {
      "start": 659.59,
      "end": 660.59,
      "text": "老龍"
    },
    {
      "start": 660.59,
      "end": 661.59,
      "text": "最基本的框架"
    },
    {
      "start": 661.59,
      "end": 662.59,
      "text": "你都給推翻了"
    },
    {
      "start": 662.59,
      "end": 663.59,
      "text": "那沒得了嗎"
    },
    {
      "start": 663.59,
      "end": 664.59,
      "text": "之前也說了"
    },
    {
      "start": 664.59,
      "end": 666.59,
      "text": "頂火"
    },
    {
      "start": 666.59,
      "end": 667.59,
      "text": "都有分"
    },
    {
      "start": 667.59,
      "end": 669.59,
      "text": "那三位南方火"
    },
    {
      "start": 669.59,
      "end": 670.59,
      "text": "什麼火"
    },
    {
      "start": 670.59,
      "end": 675.72,
      "text": "這就是"
    },
    {
      "start": 675.72,
      "end": 676.72,
      "text": "為什麼有的"
    },
    {
      "start": 676.72,
      "end": 677.72,
      "text": "永遠都不會"
    },
    {
      "start": 677.72,
      "end": 679.72,
      "text": "也許不出來"
    },
    {
      "start": 679.72,
      "end": 680.72,
      "text": "雪不成的原因"
    },
    {
      "start": 680.72,
      "end": 681.72,
      "text": "就在這"
    },
    {
      "start": 681.72,
      "end": 683.72,
      "text": "就好比三合"
    },
    {
      "start": 683.72,
      "end": 685.72,
      "text": "五馬狗也合火"
    },
    {
      "start": 685.72,
      "end": 687.72,
      "text": "何什麼火"
    },
    {
      "start": 687.72,
      "end": 689.72,
      "text": "你基礎中的基礎"
    },
    {
      "start": 689.72,
      "end": 690.72,
      "text": "但是翻書"
    },
    {
      "start": 690.72,
      "end": 692.72,
      "text": "會大概的腳步著澳"
    },
    {
      "start": 692.72,
      "end": 694.72,
      "text": "而且怎麼求認他是"
    },
    {
      "start": 694.72,
      "end": 696.72,
      "text": "對的還是錯的東西"
    },
    {
      "start": 696.72,
      "end": 697.72,
      "text": "那就是我體"
    },
    {
      "start": 697.72,
      "end": 703.94,
      "text": "三合的五馬狗"
    },
    {
      "start": 703.94,
      "end": 704.94,
      "text": "合什麼火"
    },
    {
      "start": 704.94,
      "end": 707.94,
      "text": "三位的四五位南方火"
    },
    {
      "start": 707.94,
      "end": 713.02,
      "text": "十天剛剛十二弟子"
    },
    {
      "start": 713.02,
      "end": 714.02,
      "text": "經目水火"
    },
    {
      "start": 714.02,
      "end": 716.02,
      "text": "土都有分"
    },
    {
      "start": 716.02,
      "end": 717.02,
      "text": "那想法"
    },
    {
      "start": 717.02,
      "end": 719.02,
      "text": "一解到那個水平上"
    },
    {
      "start": 720.02,
      "end": 722.02,
      "text": "這種都亂不清都不懂"
    },
    {
      "start": 722.02,
      "end": 724.02,
      "text": "或者一般的一般猜一個"
    },
    {
      "start": 724.02,
      "end": 726.02,
      "text": "十邊猜一個一般一般"
    },
    {
      "start": 726.02,
      "end": 727.02,
      "text": "這種這個"
    },
    {
      "start": 727.02,
      "end": 728.02,
      "text": "所以就沒不要說話了"
    },
    {
      "start": 728.02,
      "end": 730.02,
      "text": "去沉澱沉澱吧"
    },
    {
      "start": 731.02,
      "end": 733.02,
      "text": "用心聽的話"
    },
    {
      "start": 733.02,
      "end": 735.02,
      "text": "我已經點了很多人"
    },
    {
      "start": 735.02,
      "end": 738.94,
      "text": "比如為什麼不要"
    },
    {
      "start": 738.94,
      "end": 739.94,
      "text": "軟件看"
    },
    {
      "start": 739.94,
      "end": 741.94,
      "text": "或者說實際上垃圾片"
    },
    {
      "start": 741.94,
      "end": 742.94,
      "text": "包括所謂的"
    },
    {
      "start": 742.94,
      "end": 744.94,
      "text": "這個身上"
    },
    {
      "start": 744.94,
      "end": 745.94,
      "text": "是現金初步"
    },
    {
      "start": 745.94,
      "end": 747.94,
      "text": "食品說過很多次"
    },
    {
      "start": 747.94,
      "end": 748.94,
      "text": "還給你們看"
    },
    {
      "start": 748.94,
      "end": 750.94,
      "text": "像有一個神社有多少"
    },
    {
      "start": 751.94,
      "end": 753.94,
      "text": "不是天剛地質兩個東西"
    },
    {
      "start": 753.94,
      "end": 754.94,
      "text": "或者說是三個東西"
    },
    {
      "start": 754.94,
      "end": 755.94,
      "text": "或者說幾個東西"
    },
    {
      "start": 755.94,
      "end": 757.94,
      "text": "對待一起就是那個東西"
    },
    {
      "start": 757.94,
      "end": 760.94,
      "text": "是有主次分明的"
    },
    {
      "start": 760.94,
      "end": 762.94,
      "text": "不是有就是"
    },
    {
      "start": 762.94,
      "end": 763.94,
      "text": "明白嗎"
    },
    {
      "start": 763.94,
      "end": 765.94,
      "text": "能不能明白"
    },
    {
      "start": 765.94,
      "end": 766.94,
      "text": "那些拿著神社"
    },
    {
      "start": 766.94,
      "end": 768.94,
      "text": "天天逼逼到的"
    },
    {
      "start": 768.94,
      "end": 769.94,
      "text": "逼來來的"
    },
    {
      "start": 769.94,
      "end": 771.94,
      "text": "不是說天剛地質"
    },
    {
      "start": 771.94,
      "end": 774.94,
      "text": "其中某個元素跟某個元素"
    },
    {
      "start": 774.94,
      "end": 775.94,
      "text": "結合起來"
    },
    {
      "start": 775.94,
      "end": 777.94,
      "text": "就是那個神社的"
    },
    {
      "start": 777.94,
      "end": 778.94,
      "text": "不是的"
    },
    {
      "start": 778.94,
      "end": 780.94,
      "text": "我拿四五位這個來舉例"
    },
    {
      "start": 780.94,
      "end": 782.94,
      "text": "已經明白了點名了"
    },
    {
      "start": 782.94,
      "end": 783.94,
      "text": "告訴你"
    },
    {
      "start": 783.94,
      "end": 785.94,
      "text": "即便他們擺在一起"
    },
    {
      "start": 785.94,
      "end": 787.94,
      "text": "也要分主次"
    },
    {
      "start": 787.94,
      "end": 790.94,
      "text": "先後來進行幾毒"
    },
    {
      "start": 790.94,
      "end": 792.94,
      "text": "不是說跟連連看一樣"
    },
    {
      "start": 792.94,
      "end": 793.94,
      "text": "連到群隊"
    },
    {
      "start": 793.94,
      "end": 794.94,
      "text": "就是"
    },
    {
      "start": 794.94,
      "end": 796.94,
      "text": "或者說是消消樂"
    },
    {
      "start": 796.94,
      "end": 797.94,
      "text": "那種"
    },
    {
      "start": 797.94,
      "end": 799.94,
      "text": "連最基礎的"
    },
    {
      "start": 799.94,
      "end": 800.94,
      "text": "就能蠻動的一斤"
    },
    {
      "start": 800.94,
      "end": 802.94,
      "text": "沒分析教前的書看"
    },
    {
      "start": 802.94,
      "end": 804.94,
      "text": "就去給別人看"
    },
    {
      "start": 805.94,
      "end": 806.94,
      "text": "那為為你自己"
    },
    {
      "start": 806.94,
      "end": 807.94,
      "text": "你能看多少"
    },
    {
      "start": 807.94,
      "end": 811.02,
      "text": "極竅前的書"
    },
    {
      "start": 811.02,
      "end": 812.02,
      "text": "就越悄悄"
    }
  ]
}