    },
    {
      "start": 138.3,
      "end": 141.66,
      "text": "我已经应该打出来了"
    },
    {
      "start": 141.66,
      "end": 142.86,
      "text": "我妈就很明明"
    },
    {
      "start": 142.86,
      "end": 152.73,
      "text": "电话的蝦"
    },
    {
      "start": 152.73,
      "end": 158.81,
      "text": "刚好就有"
    },
    {
      "start": 158.81,
      "end": 160.05,
      "text": "首先你不要搞清楚"
    },
    {
      "start": 160.05,
      "end": 160.61,
      "text": "你倒不凡人"
    },
    {
      "start": 160.61,
      "end": 161.33,
      "text": "他乱了"
    },
    {
      "start": 161.33,
      "end": 163.82,
      "text": "你们和一样花"
    },
    {
      "start": 163.82,
      "end": 165.26,
      "text": "或者是礼花的"
    },
    {
      "start": 165.26,
      "end": 169.22,
