      "text": "我说有的是"
    },
    {
      "start": 188.79,
      "end": 189.95,
      "text": "中说法是不是"
    },
    {
      "start": 189.95,
      "end": 192.47,
      "text": "这个财神交过眉码"
    },
    {
      "start": 192.47,
      "end": 193.51,
      "text": "很难夜怕了"
    },
    {
      "start": 193.51,
      "end": 194.39,
      "text": "你用泡着你去"
    },
    {
      "start": 194.39,
      "end": 196.9,
      "text": "他点"
    },
    {
      "start": 196.9,
      "end": 199.06,
      "text": "灯热灯热点火点火"
    },
    {
      "start": 199.06,
      "end": 199.9,
      "text": "哇"
    },
    {
      "start": 199.9,
      "end": 201.42,
      "text": "所以说"
    },
    {
      "start": 201.42,
      "end": 202.14,
      "text": "有的人"
    },
    {
      "start": 202.14,
      "end": 203.66,
      "text": "连白神都不会白"
    },
    {
      "start": 203.66,
      "end": 205.78,
      "text": "你要应该是应该用你的"
