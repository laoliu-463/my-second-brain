    },
    {
      "start": 717.04,
      "end": 718.04,
      "text": "一也"
    },
    {
      "start": 718.04,
      "end": 722.22,
      "text": "所以我不乐成是显化"
    },
    {
      "start": 722.22,
      "end": 724.22,
      "text": "我知道换化"
    },
    {
      "start": 724.22,
      "end": 725.22,
      "text": "就是一个东西"
    },
    {
      "start": 725.22,
      "end": 727.22,
      "text": "会变成很多种形式"
    },
    {
      "start": 727.22,
      "end": 728.22,
      "text": "在一个合适的时候"
    },
    {
      "start": 728.22,
      "end": 730.22,
      "text": "显进又发出来给你"
    },
    {
      "start": 730.22,
      "end": 732.22,
      "text": "觉得不恰的历子"
    },
    {
      "start": 732.22,
      "end": 733.22,
      "text": "不恰的历子"
    },
    {
      "start": 733.22,
      "end": 735.22,
      "text": "有人说"
    },
    {
      "start": 735.22,
      "end": 737.22,
      "text": "有些人找不到媳妇"
    },
    {
      "start": 737.22,
      "end": 739.22,
      "text": "就被你找到媳妇"
    },
    {
      "start": 739.22,
      "end": 740.22,
      "text": "那有去买一只鳥"
    },
    {
      "start": 740.22,
      "end": 744.61,
      "text": "我们来一下"
    },
    {
      "start": 744.61,
      "end": 745.61,
      "text": "那下辈子"
    },
    {
      "start": 745.61,
      "end": 747.61,
      "text": "他会变成媳妇"
    },
    {
      "start": 747.61,
      "end": 748.61,
      "text": "飞到我那里"
    },
    {
      "start": 748.61,
      "end": 750.61,
      "text": "我们恰的案子"
    }
  ]
}