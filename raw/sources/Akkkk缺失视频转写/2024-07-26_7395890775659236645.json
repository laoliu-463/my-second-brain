  "duration": 83.01275,
  "segments": [
    {
      "start": 0.0,
      "end": 2.96,
      "text": "我之前又出过一期教你们怎么去"
    },
    {
      "start": 2.96,
      "end": 4.56,
      "text": "叫更好的工作"
    },
    {
      "start": 4.56,
      "end": 8.4,
      "text": "我说是下有更公图能够提告诉你的收入"
    },
    {
      "start": 8.4,
      "end": 10.24,
      "text": "中午说到应该学会学"
    },
    {
      "start": 10.24,
      "end": 13.52,
      "text": "装学会去包装自己的与利益"
    },
    {
      "start": 13.52,
      "end": 15.12,
      "text": "经验等等"
    },
    {
      "start": 15.12,
      "end": 16.56,
      "text": "没有人是不装的"
    },
    {
      "start": 16.56,
      "end": 18.16,
      "text": "包装你的与利益"
    },
    {
      "start": 18.16,
      "end": 21.24,
      "text": "与利商面稍微扩折大一些"
    },
    {
      "start": 21.24,
      "end": 24.08,
      "text": "装出一些来的许程床的事情"
    },
    {
      "start": 24.08,
      "end": 26.08,
      "text": "为了更好的一个心思"
    },
    {
      "start": 26.08,
      "end": 27.12,
      "text": "提供收入"
    },
    {
      "start": 27.12,
      "end": 28.32,
      "text": "这能理解"
    },
    {
      "start": 28.32,
      "end": 29.92,
      "text": "但是你要搞清楚"
    },
    {
      "start": 29.92,
      "end": 34.16,
      "text": "装包装还要造假的与利益"
    },
    {
      "start": 34.16,
      "end": 35.2,
      "text": "OK"
    },
    {
      "start": 35.2,
      "end": 38.24,
      "text": "就那今天我在装配一个赶回的时候"
    },
    {
      "start": 38.24,
      "end": 40.0,
      "text": "我们明确表示该赶回"
    },
    {
      "start": 40.0,
      "end": 41.52,
      "text": "一定要为英文"
    },
    {
      "start": 41.52,
      "end": 46.35,
      "text": "一定要够流畅够的"
    },
    {
      "start": 46.35,
      "end": 47.87,
      "text": "该不来英文评"
    },
    {
      "start": 47.87,
      "end": 49.55,
      "text": "与利商面系"
    },
    {
      "start": 49.55,
      "end": 50.91,
      "text": "我继续的选择"
    },
    {
      "start": 50.91,
      "end": 52.51,
      "text": "是个刘子"
    },
    {
      "start": 52.51,
      "end": 55.07,
      "text": "我跟他够通用的是英文"
    },
    {
      "start": 55.07,
      "end": 56.99,
      "text": "在我巴拉巴拉的"
    },
    {
      "start": 56.99,
      "end": 59.39,
      "text": "有四十秒吧"
    },
    {
      "start": 59.39,
      "end": 60.83,
      "text": "他给我来英文"
    },
    {
      "start": 60.83,
      "end": 62.03,
      "text": "我不会英文"
    },
    {
      "start": 62.03,
      "end": 63.71,
      "text": "我的方"
    },
    {
      "start": 63.71,
      "end": 65.31,
      "text": "我的方"
    },
    {
      "start": 65.31,
      "end": 67.23,
      "text": "我真是被我理得太阳"
    },
    {
      "start": 67.23,
      "end": 68.99,
      "text": "我日期的我呀"
    },
    {
      "start": 68.99,
      "end": 71.31,
      "text": "典套体游心天宁该批创"
    },
    {
      "start": 71.31,
      "end": 73.87,
      "text": "包装够推一切的基础"
    },
    {
      "start": 73.87,
      "end": 74.91,
      "text": "不要远远远"
    },
    {
      "start": 74.91,
      "end": 76.83,
      "text": "真的远住"
    },
    {
      "start": 76.83,
      "end": 78.43,
      "text": "真的有一定的"
    },
    {
      "start": 78.43,
      "end": 80.67,
      "text": "基础实力在呢"
    },
    {
      "start": 80.67,
      "end": 81.47,
      "text": "好吧"
    },
    {
      "start": 81.47,
      "end": 83.07,
      "text": "那就是套假"
    }
  ]
}