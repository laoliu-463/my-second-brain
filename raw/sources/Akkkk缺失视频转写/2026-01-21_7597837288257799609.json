    {
      "start": 292.21,
      "end": 293.21,
      "text": "不能的情绪"
    },
    {
      "start": 294.21,
      "end": 295.21,
      "text": "有什么意义呀"
    },
    {
      "start": 295.21,
      "end": 296.21,
      "text": "改变你的生活了吗"
    },
    {
      "start": 297.21,
      "end": 298.21,
      "text": "改变你什么了"
    },
    {
      "start": 298.21,
      "end": 301.0,
      "text": "无礼"
    },
    {
      "start": 301.0,
      "end": 302.0,
