    {
      "start": 344.67,
      "end": 345.67,
      "text": "以来也会"
    },
    {
      "start": 345.67,
      "end": 346.67,
      "text": "那通知到什么时候"
    },
    {
      "start": 346.67,
      "end": 347.67,
      "text": "你什么时候"
    },
    {
      "start": 347.67,
      "end": 348.67,
      "text": "就那么显示"
    },
    {
      "start": 349.67,
      "end": 350.67,
      "text": "比我过得好了"
    },
    {
      "start": 350.67,
      "end": 351.67,
      "text": "比我有钱"
    },
    {
      "start": 351.67,
      "end": 352.67,
      "text": "比我有地位"
    },
    {
      "start": 352.67,
      "end": 353.67,
      "text": "有失利"
    },
    {
      "start": 353.67,
      "end": 355.67,
      "text": "因为你有那么显"
    },
    {
      "start": 356.67,
      "end": 357.67,
      "text": "我都嫌自己不够"
    },
    {
      "start": 357.67,
      "end": 358.67,
      "text": "现在平冷命的"
    },
    {
      "start": 358.67,
      "end": 360.67,
      "text": "都是要晚上在跑"
