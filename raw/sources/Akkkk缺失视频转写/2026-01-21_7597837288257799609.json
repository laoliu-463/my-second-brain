    {
      "start": 281.21,
      "end": 282.21,
      "text": "丁不终"
    },
    {
      "start": 282.21,
      "end": 283.21,
      "text": "还天天"
    },
    {
      "start": 283.21,
      "end": 284.21,
      "text": "隔车"
    },
    {
      "start": 284.21,
      "end": 286.21,
      "text": "去债一那些调调"
    },
    {
      "start": 288.21,
      "end": 289.21,
      "text": "气倒很温呢"
    },
    {
      "start": 290.21,
      "end": 291.21,
      "text": "就知道在这后面"
    },
    {
      "start": 291.21,
      "end": 292.21,
      "text": "晚上算发"
