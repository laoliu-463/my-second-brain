      "start": 310.88,
      "end": 311.88,
      "text": "还有一个需要"
    },
    {
      "start": 311.88,
      "end": 312.88,
      "text": "你跟人家真子"
    },
    {
      "start": 313.88,
      "end": 314.88,
      "text": "不要说话那么难听"
    },
    {
      "start": 315.88,
      "end": 316.88,
      "text": "确实有点难听"
    },
    {
      "start": 316.88,
      "end": 318.88,
      "text": "又是攻击这种"
    },
    {
      "start": 318.88,
      "end": 319.88,
      "text": "保抗老"
    },
    {
      "start": 319.88,
      "end": 320.88,
      "text": "说难听"
    },
    {
      "start": 320.88,
      "end": 321.88,
      "text": "大部分年前"
    },
    {
      "start": 321.88,
      "end": 322.88,
      "text": "现在谁没可能"
    },
    {
      "start": 322.88,
      "end": 323.88,
      "text": "分钟不不"
    },
    {
      "start": 323.88,
      "end": 324.88,
      "text": "我们这个在人"
    },
    {
      "start": 324.88,
      "end": 325.88,
      "text": "其实全第一名的时候"
    },
    {
      "start": 325.88,
      "end": 326.88,
      "text": "大家一些"
    },
    {
      "start": 326.88,
      "end": 328.88,
      "text": "都有可能老的这么多"
    },
    {
      "start": 328.88,
      "end": 329.88,
